@await Html.PartialAsync("PartialView/_PartialViewCredencial")
@* @await Html.PartialAsync("PartialView/_PartialViewRecarga") *@


@section Scripts {
    <script src="~/js/3th/jquery.maskmoney.min.js"></script>
    <script src="~/js/detectaBandeira.js"></script>
    <script src="~/js/pagamento/cardpix.js"></script>
    <script src="~/js/3th/loadingoverlay.min.js"></script>

    @if (correcao != null)
    {
        <script>
            $(document).ready(function () {
                $('#modal-msg').modal('show')
            });
        </script>
    }
    <script>


        document.addEventListener('DOMContentLoaded', function () {
            fetch('/cliente/get-credencial/' + '@Model?.Nucpf')
                .then(response => response.text())
                .then(data => {
                    // console.log(data);
                    document.getElementById('img-credencial').src = data;
                })
                .catch(error => console.error('Erro ao buscar credencial:', error));


            $('#loadPartialButton').click(function () {
                $.ajax({
                    url: '/cliente/partialview-recarga/' + '@Model?.Nucpf',
                    type: 'GET',
                    success: function (result) {
                        $('#partialRecarga').html(result);
                        $('#modal-recarga').modal('show');
                    },
                    error: function (xhr, status, error) {
                        console.error(error);
                    }
                });
            });
        });

        function ava(cpf) {
            $.ajax({
                url: '@Url.Action("LoginMoodle")/' + '?cpf=' + cpf,
                type: 'GET',
                success: function (data) {
                    if (data.code === 1) {
                        window.open(data.url, '_blank');
                    } else {
                        swal({
                            title: 'Ops',
                            text: 'Desculpe, tente novamente mais tarde',
                            icon: 'warning',
                            timer: 1500
                        });
                    }
                    //console.log("url: " + data.url);

                },
                error: function () {
                    alert("error");
                }
            });
        }

        function getRematricula(cpf) {
            $.ajax({
                url: '/cliente/obter-dependentes-rematricula/' + cpf,
                type: 'GET',
                beforeSend: function () {
                    $.LoadingOverlay("show",
                        {
                            background: "rgba(176, 177, 178, 0.5)",
                            text: "Aguarde..."
                        });
                },
                complete: function () {
                    $.LoadingOverlay("hide");
                },
                success: function (data) {
                    if (data != null) {
                        console.log(data);
                        $('#dependentesRematricula').empty();

                        $.each(data.clientes, function (index, value) {
                            $('#dependentesRematricula').append('<a href="/cliente/rematricula/matriculas-cliente?cpf=' + value.nucpf + '"> <div class="card card-accordion shadow-border rounded"  style="margin-bottom: 20px"><div class="col-md-12"> <div class="row"> <div class="col-md-2"> <img src="' + value.fotoCliente + '" style="height: 100px; width: 100px; border-radius:100px; object-fit: cover; border: 5px solid white" alt="foto-cliente" /> </div> <div class="col-md-6"> <p class="text-bold mb-0"> ' + value.nmcliente + ' </p> <p class="mb-0"> Matrícula: ' + value.matricula + ' </p> <p class="mb-0"> CPF:  ' + value.nucpf + ' </p> </div> </div> </div> </div> </div> </a>');
                        });

                        $('#modalRematricula').modal('show');
                    } else {
                        swal({
                            title: 'Ops',
                            text: 'Desculpe, tente novamente mais tarde',
                            icon: 'warning',
                            timer: 1500
                        });
                    }
                },
                error: function () {
                    swal({
                        title: 'Ops',
                        text: 'Desculpe, tente novamente mais tarde',
                        icon: 'warning',
                        timer: 1500
                    });
                }
            });
        }

        function movimentacao(numcartao) {
            fetch('/cliente/movimentacao-cartao/' + '@Model.Numcartao')
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('modal-consumo');
                    console.log(data);
                    const table = document.createElement('table');
                    table.classList.add('table', 'table-hover');
                    table.id = 'tdMovimentacaoCartaoCliente';

                    // Criar thead
                    const thead = document.createElement('thead');
                    const headerRow = document.createElement('tr');

                    const headers = ['PRODUTO', 'DATA', 'HORA', 'VALOR'];
                    headers.forEach(headerText => {
                        const th = document.createElement('th');
                        th.textContent = headerText;
                        headerRow.appendChild(th);
                    });

                    thead.appendChild(headerRow);
                    table.appendChild(thead);

                    // Criar tbody
                    const tbody = document.createElement('tbody');


                    data.forEach(cons => {
                        // Criação do elemento <tr>
                        const tr = document.createElement('tr');

                        // Criação do elemento <td> para dsproduto
                        const tdProduto = document.createElement('td');
