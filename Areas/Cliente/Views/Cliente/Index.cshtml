@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model SiteSesc.Models.ApiPagamento.ClienteCentral
@using SiteSesc.Models.ApiPagamento
@using SiteSesc.Services
@using SiteSesc.Models.ModelPartialView;
@{
    ViewData["Title"] = "Espaço do cliente";
    var dependentes = ViewBag.Dependentes as List<ClienteDetails>;
    var correcao = ViewBag.Correcao as HstSolicitacao;
    bool clienteCredenciado = true;
    var usuario = ViewBag.Usuario as Usuario;
    int anoExpiracao = DateTime.Now.Year;
    int? tipoCategoria = ViewBag.TipoCategoria;
    string categoria = ViewBag.Categoria;
    var movimentacao = ViewBag.Movimentacao as List<HSTMOVCART>;
}
<link href="~/css/espacocliente/cardpagamento.css" rel="stylesheet" />

<style>

    .rating-container {
        display: inline-block;
        direction: rtl; /* Isso faz com que as estrelas sejam renderizadas da direita para a esquerda */
    }

    .rating-star {
        font-size: 25px;
        color: #d9d7d2;
        cursor: pointer;
        display: inline-block;
        padding: 0 5px;
        transition: color 0.2s;
    }

        .rating-star:hover,
        .rating-star:hover ~ .rating-star {
            color: #deb217;
        }


    a {
        cursor: pointer
    }

    #btn-switch {
        padding: clamp(0.3rem, 0.3rem + 1vh, 0.6rem) 1.5rem;
        margin-left: 2rem;
    }

    .img-circular {
        position: relative;
        width: 200px;
        height: 200px;
        object-fit: cover;
        border-radius: 50%
    }

    .PrimeiroSegundoNome {
        text-transform: capitalize;
    }

    .container-dep, .portfolio-wrap {
        position: relative;
        width: 200px;
        height: 200px;
        border-radius: 50%;
    }

    .portfolio-info {
        position: relative;
        margin: 20px;
    }

        .portfolio-info h4 {
            font-size: 18px !important;
            margin: 15px;
            position: absolute;
            cursor: default;
        }

    .portfolio .portfolio-wrap::before {
        border-radius: 50%;
    }

    .portfolio .portfolio-wrap .portfolio-info::before {
        display: block;
        content: "";
        width: 48px;
        height: 48px;
        position: absolute;
        top: 0;
        left: 0;
        border-top: 3px solid #004c99;
        border-left: 3px solid #004c99;
        transition: all 0.5s ease 0s;
        z-index: 1;
    }

    .portfolio .portfolio-wrap .portfolio-info::after {
        display: block;
        content: "";
        width: 48px;
        height: 48px;
        position: absolute;
        bottom: 0;
        right: 0;
        border-bottom: 3px solid #004c99;
        border-right: 3px solid #004c99;
        transition: all 0.5s ease 0s;
        z-index: 1;
    }

    .portfolio-links {
        position: relative;
        margin-top: 140px;
    }


        .portfolio-links .bx-search-alt {
            transition: 0.8s ease;
        }

        .portfolio-links:hover .bx-search-alt {
            scale: 150%;
            transition: 0.5s ease;
        }


    #dependentesContainer {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0 !important;
        margin: 0 !important;
        gap: 2rem;
    }

    .totalArea {
        width: 100%;
    }

    .container-dep, .portfolio-wrap {
        padding: 0 !important;
        margin: 0 !important;
    }

    .botoesCredenciaisContainer {
        display: flex;
        flex-direction: column;
        align-items: start;
        width: fit-content;
    }

    .botaoCredenciais {
        max-width: 220px;
    }

    .superiores {
        display: flex;
        flex-direction: row;
        justify-content: flex-start;
        gap: 1rem;
        width: fit-content;
    }

    .bcAzul, .bcTransparente {
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.5s;
        margin-top: 2rem !important;
    }

    .bcAzul {
        background-color: #004c99;
    }

        .bcAzul:hover {
            background-color: #3866e8;
        }

    .bcTransparente:hover {
        background-color: rgba(56,102,232,0.2);
    }

    .btnRenovacao {
        transition: 0.5s;
        margin-top: 2rem !important;
        background: transparent;
        border: 2px solid #0563bb;
        color: #0563bb;
    }

    .bg-transaparent {
        background: transparent;
        border: 2px solid #0563bb;
        color: #0563bb;
    }

    .renovarCredencial {
        color: #fff;
        width: 100%;
        background: linear-gradient(90deg, rgba(255,0,0,0.5) 0%, rgba(255,0,0,0.5) 20%, rgba(255,0,0,1) 80%, rgba(255,0,0,1) 100%);
        background-size: 600%;
        background-position: 0%;
        cursor: pointer;
        border: 2px solid rgba(255,0,0, 1);
        min-height: 80px;
        position: relative;
        z-index: 0;
        border-radius: 40PX;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        animation: glowing 2.3s linear 1;
        transition: all .3s ease;
    }

    @@keyframes glowing {
        0% {
            background: rgba(5,99,187, 0);
            border: 2px solid rgba(5,99,187,1);
            color: #0563bb
        }

        60% {
            background: rgba(5,99,187, 0);
            border: 2px solid rgba(5,99,187,1);
            color: #0563bb;
            box-shadow: 0 0 15px rgba(255,0,0, 0);
        }

        80% {
            background: rgba(255,0,0, 0.9);
            border: 2px solid rgba(255,0,0, 1);
            color: white;
            box-shadow: 0 0 15px rgba(255,0,0, 0.3);
        }

        100% {
            background: rgba(255,0,0, 0.5);
            border: 2px solid rgba(255,0,0, 1);
            color: white;
        }
    }

    .renovarCredencial:hover {
        box-shadow: 0px 2px 5px rgba(0, 0, 0, 0.3);
        transform: translateY(-5px);
        background-position: 100%;
        transition: all 1s ease;
    }



    @@media only screen and (max-width: 992px) {
        .botoesCredenciaisContainer {
            align-items: center;
            justify-content: center;
            margin: auto;
        }

        .superiores {
            justify-content: center;
        }

        .nomeMeusDados {
            text-align: center;
        }

        .imagemMeusDados {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .areaSaldo {
            padding-top: 2rem;
        }
    }


    @@media only screen and (min-width: 768px) {
    }

    @@media only screen and (max-width: 767px) {
        .botoesCredenciaisContainer {
            flex-direction: column;
            align-items: center;
        }

        .superiores {
            flex-direction: column;
            align-items: center;
            gap: 0;
        }
    }

    .tp-entrada {
        color: green !important;
    }

    .tp-saida {
        color: red !important;
    }
</style>

@await Component.InvokeAsync("SideMenu", new { area = "cliente" })

@if (!clienteCredenciado)
{
    <section id="hero" class="d-flex flex-column justify-content-center">

        <div class="container" data-aos="zoom-in" data-aos-delay="100">
            <h1 class="PrimeiroSegundoNome">Olá, @Util.PrimeiroSegundoNome(Model.Nmcliente.ToLower()).</h1>
            @if (ViewBag.HasSolicitacao ?? false)
            {
                <p><i class="fa-solid fa-circle-exclamation" style="color:dodgerblue"></i>&nbsp; Você possui uma solicitação em análise...</p>
            }
        </div>
    </section>
}
else
{

    <section id="hero" class="d-flex flex-column justify-content-center">

        <div class="container" data-aos="zoom-in" data-aos-delay="100">
            <h1 class="PrimeiroSegundoNome">Olá, @Util.PrimeiroSegundoNome(Model.Nmcliente.ToLower()).</h1>
            @if (ViewBag.HasSolicitacao ?? false)
            {
                <p><i class="fa-solid fa-circle-exclamation" style="color:dodgerblue"></i>&nbsp; Você possui uma solicitação em análise...</p>
            }
            <div class="row text-center botoesCredenciaisContainer">
                <div class="superiores">
                    <div class="botaoCredenciais">
                        <a id="loadPartialButton">
                            <div class="btn-rounded bg-blue tex-center mt-5 bcAzul">Recarregar Credencial Sesc</div>
                        </a>
                    </div>
                    <div class="botaoCredenciais">
                        <a data-bs-toggle="modal" data-bs-target="#modal-credencial">
                            <div class="btn-rounded bg-transaparent text-center mt-5 bcTransparente">Ver Credencial Sesc</div>
                        </a>
                    </div>

                </div>
                @if (ViewBag.Renovacao ?? false)
                {
                    if (ViewBag.HasSolicitacao == false)
                    {
                        <div class="totalArea">
                            <a asp-action="Renovacao" asp-controller="SolicitacaoCadastroCliente" asp-route-CDUOP="@Model.Cduop" asp-route-SQMATRIC="@Model.Sqmatric">
                                <div class="btn-rounded btnRenovacao renovarCredencial" id="botaoRenovacao">Renove Sua Credencial</div>
                            </a>
                        </div>
                    }

                }
            </div>

            <div class="areaSaldo">
                <p>Saldo na sua Credencial Sesc: <span id="saldoContainer"></span></p>
            </div>
        </div>
    </section>

    <main id="main">
        <section id="perfil" class="about">
            <div class="container" data-aos="fade-up">
                <div class="section-title">
                    <h2>Meus dados</h2>
                    <p>Esses são os dados no Sesc, caso precise alterar alguma informação entre em contato com a Central de Atendimentos!</p>
                </div>
                <div class="row">
                    <div class="col-lg-4 imagemMeusDados">
                        <img src="@Model.FotoCliente" class="img-fluid" alt="" style="border-radius: 50%">
                    </div>
                    <div class="col-lg-8 pt-4 pt-lg-0 content">
                        <h3 class="nomeMeusDados">@Model.Nmcliente</h3>
                        <div class="row">
                            <div class="col-lg-12">
                                <ul>
                                    <li><i class="bi bi-chevron-right"></i> <strong>Credencial Sesc:</strong> <span>@Model.Credencial</span></li>
                                    <li><i class="bi bi-chevron-right"></i> <strong>Categoria:</strong> <span>@categoria</span>
                                    <li><i class="bi bi-chevron-right"></i> <strong>CPF:</strong> <span>@Model.Nucpf.Substring(0, 3).***.***-@Model.Nucpf.Substring(@Model.Nucpf.Length - 2)</span></li>
                                        @* <li><i class="bi bi-chevron-right"></i> <strong>RG:</strong> <span>@Model.Nureggeral</span></li> *@
                                        @if (Model.Enderecos.Any())
                                        {
                                        <li><i class="bi bi-chevron-right"></i> <strong>Endereço:</strong> <span>@Model.Enderecos.FirstOrDefault().EnderecoCompleto</span></li>

                                        }
                                    <li><i class="bi bi-chevron-right"></i> <strong>Email:</strong> <span>@usuario?.Email</span></li>
                                </ul>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="matriculas" class="resume">
            <div class="container" data-aos="fade-up">
                <div class="section-title">
                    <h2>Minhas matrículas e serviços</h2>
                    <p>Essas são suas matrículas ativas no Sesc @Configuration["Ambiente:UF"]</p>
                </div>
                <div class="row">
                    <div id="matriculasContainer" class="row"></div>
                </div>
            </div>
        </section>

        @if (Model.Cduotitul == null)
        {
            <section id="dependentes" class="portfolio section-bg">
                <div class="container" data-aos="fade-up">
                    <div class="section-title">
                        <h2>Dependentes</h2>

                        @if (tipoCategoria != null)
                        {
                            if (tipoCategoria != 1)
                            {
                                <a asp-action="Create" asp-controller="SolicitacaoCadastroCliente" asp-area="Cliente" asp-route-categoria="@tipoCategoria" asp-route-CDUOTITUL="@Model.Cduop" asp-route-SQTITULMAT="@Model.Sqmatric" class="btn-sm btn-rounded bg-transaparent">Adicionar dependente</a>
                            }
                        }

                        <p class="mt-3">Aqui estão relacionados seus dependentes</p>

                    </div>

                    <div id="dependentesContainer" class="row " data-aos="fade-up" data-aos-delay="200"></div>

                </div>
            </section>
        }


        <section id="cobrancas" class="services">
            <div class="container" data-aos="fade-up">

                <div class="section-title">
                    <h2>Minhas cobranças</h2>
                    <p>Aqui estão relacionadas as próximas cobranças em aberto ou pendentes</p>
                    <br>
                    @if (Model.Cduotitul != null)
                    {
                        <a asp-action="CobrancasPorCpf" asp-controller="Cobranca" asp-route-cpfDependente="@Model.Nucpf"><p>Ver todas as cobranças</p></a>
                    }
                    else
                    {
                        <a asp-action="CobrancasPorCpf" asp-controller="Cobranca"><p>Ver todas as cobranças</p></a>
                    }
                </div>
                <div id="cobrancasContainer" class="row"></div>
            </div>
        </section>
    </main>
}

