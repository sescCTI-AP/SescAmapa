@section Scripts
{
    <script src="~/js/SolicitacaoCadastro/wizard-navigation.js"></script>
    <script>

        $(document).ready(function () {

            getBase64ImageFromURL('@arquivos.FirstOrDefault(a => a.Tipo == "FotoPerfil").Arquivo.CaminhoVirtualFormatado()')
                .then(base64 => document.getElementById('div-foto-perfil').style.backgroundImage = "url('" + base64 + "')")
                .catch(error => console.error(error));


            //<--- AÇÕES AO CARREGAR E MASCARAS --->
            $('#Cep').mask('99999-999');
            $('#DataNascimento').mask('99/99/9999');
            $('#ComerciarioEmpresaPreCadastro_CnpjEmpresa').mask('00.000.000/0000-00');
            $('#PisPasep').mask('000.00000.00-0')
            $('#validacao').modal('show');
            var behavior = function (val) {
                return val.replace(/\D/g, '').length === 11 ? '(00) 00000-0000' : '(00) 0000-00009';
            },
                options = {
                    onKeyPress: function (val, e, field, options) {
                        field.mask(behavior.apply({}, arguments), options);
                    }
                };
            $('#Telefone').mask(behavior, options);

            //<--- AÇÕES RADIO TIPO CLIENTE --->
            $('.radio-group .radio-categoria').click(function () {
                var categoria = this.id;
                $('.selected .fa').removeClass('fa-check');
                $('.radio-categoria').removeClass('selected');
                $(this).addClass('selected');
                $('#form-dados').show();

                //<---COMERCIARIO--->
                if (categoria === 'categoria-comerciario') {
                    $('.dados-empresa').show();
                    var inputsEmpresa = document.querySelectorAll('.input-empresa');
                    inputsEmpresa.forEach(function (e) {
                        e.required = true;
                    });
                    $('#IdCategoria').val('1');
                    $('.anexo-empresa').addClass('anexo-obrigatorio')
                }
                //<---PUBLICO GERAL--->
                else {
                    $('.dados-empresa').hide();
                    var inputsEmpresa = document.querySelectorAll('.input-empresa');
                    inputsEmpresa.forEach(function (e) {
                        e.required = false;
                    });
                    $('#IdCategoria').val('2');
                    $('.anexo-empresa').removeClass('anexo-obrigatorio')
                }
            });
        });



        function navigation(idNow, idNext) {
            validateAndMoveNext('page-w-' + idNow, 'page-w-' + idNext);
        }

        function moveToPrevious(currentPageId, nextPageId) {
            document.getElementById('page-w-' + currentPageId).style.display = 'none';
            document.getElementById('page-w-' + nextPageId).style.display = 'block';
        }


        // <--- VERIFICA SE JÁ EXISTE O NUMERO DE RG --->
        $('#NumeroDocumentoIdentificacao').focusout(function () {
            let docIdentificacao = $(this).val();
            $.ajax({
                url: '@Url.Action("VerificarDocIdentificacao", "Cliente", new { area = "Cliente" })/',
                type: "POST",
                data: { docIdentificacao: docIdentificacao },
                success: function (data) {
                    if (data.Code === 1) {
                        swal({
                            text: data.Message,
                            icon: data.ClassAlert,
                        })
                    }
                },
                error: function (err) {
                    alert('teste');
                }
            });
        });

        // <--- BUSCA SE JÁ EXISTE A EMPRESA PELO CNPJ --->
        $('#CnpjEmpresa').focusout(function () {
            let cnpj = $(this).val();
            $.ajax({
                url: '@Url.Action("GetDadosEmpresaByCnpj", "SolicitacaoCadastroCliente", new { area = "Cliente" })/',
                type: "POST",
                data: { cnpj: cnpj },
                success: function (data) {
                    console.log(data);

                    if (data.code === 1) {
                        $('#RazaoSocial').val(data.data.razaoSocial);
                    }
                    else {
                        swal({
                            text: data.Message,
                            icon: data.ClassAlert,
                        })
                    }
                },
                error: function (err) {
                    alert(err);
                }
            });
        });

        // <--- BUSCA SE JÁ EXISTE PIS/PASEP --->
        // $('#PisPasep').focusout(function () {
        //     let pis = $(this).val();
        //     $.ajax({
        //         url: '@Url.Action("VerificaPisPasep", "Cliente", new { area = "Cliente" })/',
        //         type: "POST",
        //         data: { pis: pis },
        //         success: function (data) {
