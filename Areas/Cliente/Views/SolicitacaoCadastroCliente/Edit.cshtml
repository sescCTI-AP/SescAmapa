@model SiteSesc.Models.SolicitacaoCadastroCliente
@{
    Layout = "~/Views/Shared/_Default.cshtml";
    ViewBag.Title = "Editar solicitação";
    ViewBag.TipoCadastro = "Editar solicitação";
    var arquivos = ViewBag.Arquivos as List<ArquivoCadastroCliente>;
    var cduotitul = ViewBag.CDUOTITUL;

}

<link href="~/css/SolicitacaoCadastro/novoCadastro.css" rel="stylesheet" />
<link rel="stylesheet" href="~/css/SolicitacaoCadastro/app.css" type="text/css" />

@* <---Div formulario ---> *@
<div class="card bg-transparent border-0">

    @* <--Titulo--> *@
    <h3 class="mt-5 text-center" style="font-style: italic; color: dodgerblue">Trabalhador do Comércio</h3>
    <br />

    <div class="card-block px-0">
        <form method="post" asp-action="Edit" asp-controller="SolicitacaoCadastroCliente" asp-area="Cliente" enctype="multipart/form-data" id="formAlteracaoClienteComerciario" class="">

            <input value="@Model.TipoCategoria" hidden asp-for="TipoCategoria" />
            <input value="@Model.Id" hidden asp-for="Id" />
            <input value="@Model.IdUsuario" hidden asp-for="IdUsuario" />

            <div class="form-wizard col-12 ml-auto mr-auto px-0" id="form-dados">
                <div>
                    @* <--- DADOS PESSOAIS ---> *@
                    <div id="page-w-1" class="row mx-0 p-3 border shadow-sm rounded bg-white" style="display: block">
                        <h3 class="text-center w-100">DADOS PESSOAIS</h3>

                        <div class="col-md-12 pt-4 my-3">
                            <div class="row">
                                @*<--- FOTO PERFIL --->*@
                                <div class="wrap-input100 col-md-3 no-border">
                                    <div id="div-foto-perfil" class="upload shadow-sm border" style="background-size:cover;">
                                        <label asp-for="FotoPerfil" class="col-12 text-center" style="z-index: 9999; position: absolute; width: 200px; font-weight:bold">Foto de perfil</label>
                                        <input type="file" asp-for="FotoPerfil" id="FotoPerfil" descricao-documento="FotoPerfil"
                                               accept="image/*" class="foto anexo-inputs">
                                    </div>
                                </div>

                                @*<--- NOME --->*@
                                <div class="wrap-input100 col-md ml-3 no-border">
                                    @* <---Nome ---> *@
                                    <div class="wrap-input100  bg1 mt-3">
                                        <label asp-for="Nome" class="label-input100">
                                            Nome Completo
                                        </label>
                                        <input asp-for="Nome" id="Nome" class="input100"
                                               placeholder="Informe seu nome completo" required />
                                    </div>

                                    <div class="wrap-input100  bg1 mt-3">
                                        <label asp-for="NomeSocial" class="label-input100">
                                            Nome Social
                                            (opcional)
                                        </label>
                                        <input asp-for="NomeSocial" id="Nome" class="input100"
                                               placeholder="Informe o nome social" />
                                    </div>
                                </div>
                            </div>
                        </div>


                        <div class="col-md-12 pr-4 pl-4">

                            <div class="row mx-0">
                                @* <--- Estado civil ---> *@
                                <div class="wrap-input100 bg1 col-12 col-md-6 pr-2">
                                    <span class="label-input100">
                                        Estado Civil <i class="fa fa-asterisk color-red"></i>
                                    </span>
                                    <div>
                                        <select asp-for="IdEstadoCivil" asp-items="@ViewBag.IdEstadoCivil" class="js-select2" required>
                                            <option value="" selected>Selecione uma opção</option>
                                        </select>
                                        <div class="dropDownSelect2"></div>
                                    </div>
                                </div>
                                @* <--- Data de Nascimento ---> *@
                                <div class="wrap-input100 bg1 col-12 col-md ml-3">
                                    <label class="label-input100" for="DataNascimento">DATA DE NASCIMENTO<i class="fa fa-asterisk color-red"></i></label>
                                    <input type="date" asp-for="DataNascimento"
                                           class="input100 datetimepicker-input"
                                           placeholder="Selecione uma data" required />
                                </div>
                            </div>

                            <div class="row mx-0">
                                @* <--- Escolaridade ---> *@
                                <div class="wrap-input100  bg1 col-12 col-md-6 pr-2">
                                    <span class="label-input100">
                                        Escolaridade <i class="fa fa-asterisk color-red"></i>
                                    </span>
                                    <div>
                                        <select asp-for="IdEscolaridade" asp-items="@ViewBag.IdEscolaridade" class="js-select2" required>
                                            <option value="" selected>Selecione uma opção</option>
                                        </select>
                                        <div class="dropDownSelect2"></div>
                                    </div>
                                </div>

                                @* <---Ultima Serie ---> *@
                                <div class="wrap-input100  bg1 col-12 col-md ml-3">
                                    <label asp-for="UltimaSerie" class="label-input100">
                                        Última Série
                                    </label>
                                    <input asp-for="UltimaSerie" id="Nome" class="input100"
                                           placeholder="Em caso de escolaridade incompleta" />
                                </div>
                            </div>

                            <div class="row mx-0">
                                @* <--- Sexo ---> *@
                                <div class="wrap-input100  bg1 col-12 col-md-6 pr-2">
                                    <span class="label-input100">
                                        Sexo <i class="fa fa-asterisk color-red"></i>
                                    </span>
                                    <div>
                                        <select asp-for="IdSexo" asp-items="@ViewBag.IdSexo" class="js-select2" required>
                                            <option value="" selected>Selecione uma opção</option>
                                        </select>
                                        <div class="dropDownSelect2"></div>
                                    </div>
                                </div>

                                @* <--- Telefone ---> *@
                                <div class="wrap-input100  bg1 col-12 col-md ml-3">
                                    <label asp-for="TelefonePrimario" class="label-input100">
                                        Telefone <i class="fa fa-asterisk color-red"></i>
                                    </label>
                                    <input type="tel" asp-for="TelefonePrimario" id="Telefone" class="input100"
                                           placeholder="Informe o seu telefone" required />
                                </div>
                            </div>


                        </div>

                        <div class="col-md-12 pt-4 my-3 pr-4 pl-4">
                            <div class="row mx-0">
                                @*<--- NOME PAI --->*@
                                <div class="wrap-input100 bg1 col-md pr-2">
                                    <label class="label-input100" asp-for="NomePai">NOME DO PAI<i class="fa fa-asterisk color-red"></i></label>
                                    <input type="text" asp-for="NomePai" name="NomePai" class="input100" placeholder="Informe o nome do pai" required>
                                </div>

                                @*<--- NOME DA MÃE --->*@
                                <div class="wrap-input100 bg1 col-md ml-3">
                                    <label class="label-input100" asp-for="NomeMae">NOME DA MÃE<i class="fa fa-asterisk color-red"></i></label>
                                    <input type="text" asp-for="NomeMae" name="NomeMae" class="input100" placeholder="Informe o nome da mãe" required>
                                </div>
                            </div>

                            <div class="row mx-0">
                                @*<--- NACIONALIDADE --->*@
                                <div class="wrap-input100 bg1 col-md pr-2">
                                    <label asp-for="Nacionalidade" class="label-input100">Nacionalidade<i class="fa fa-asterisk color-red"></i></label>
                                    <input asp-for="Nacionalidade" id="Nome" class="input100"
                                           placeholder="Ex: Brasileiro(a)" required />
                                </div>

                                @*<--- NATURALIDADE --->*@
                                <div class="wrap-input100 bg1 col-md ml-3">
                                    <label class="label-input100" asp-for="Naturalidade">Naturalidade<i class="fa fa-asterisk color-red"></i></label>
                                    <input type="text" asp-for="Naturalidade" name="Naturalidade" class="input100" placeholder="Ex: Belém-PA" required>
                                </div>
                            </div>

                            <div class="row  mx-0">
                                @*<--- RENDA --->*@
                                <div class="wrap-input100 bg1 col-md pr-2">
                                    <label asp-for="RendaIndividual" class="label-input100">RENDA (R$)<i class="fa fa-asterisk color-red"></i></label>
                                    <input type="text" asp-for="RendaIndividual" name="Renda" class="input100 currency" onkeyup="mascaraMoeda(this, event)" placeholder="Ex: 1.412,00" required>
                                </div>
                                @*<--- RENDA FAMILIAR --->*@
                                <div class="wrap-input100 bg1 col-md ml-3">
                                    <label asp-for="RendaFamiliar" class="label-input100">RENDA FAMILIAR (R$)<i class="fa fa-asterisk color-red"></i></label>
                                    <input type="text" asp-for="RendaFamiliar" name="RendaFamiliar" class="input100" onkeyup="mascaraMoeda(this, event)" placeholder="Ex: 1.412,00" required>
                                </div>
                            </div>
                        </div>

                        @*<---DOCUMENTOS--->*@
                        <div class="col-md-12 pt-4 border-dashed my-3">
                            <h3>Documento de identificação</h3>
                            <div class="row mt-2">
                                <div class="col-md">
                                    <div class="wrap-input100  bg1">
                                        <span class="label-input100">
                                            Tipo <i class="fa fa-asterisk color-red"></i>
                                        </span>
                                        <div>
                                            <select asp-for="IdTipoDocumentoIdentificacao" asp-items="@ViewBag.IdTipoDocumentoIdentificacao" class="js-select2" required>
                                                <option value="" selected>Selecione uma opção</option>
                                            </select>
                                            <div class="dropDownSelect2"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md">
                                    <div class="wrap-input100  bg1" data-validate="Informe um número válido">
                                        <label asp-for="NumeroDocumento" class="label-input100">
                                            Número
                                            <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="NumeroDocumento" id="NumeroDocumento"
                                               class="input100" placeholder="Número do documento de identificação" required />
                                    </div>
                                </div>
                                <div class="col-md">
                                    <div class="wrap-input100  bg1" data-validate="Informe um número válido">
                                        <label asp-for="OrgaoEmissor" class="label-input100">
                                            Órgão emissor <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="OrgaoEmissor"
                                               class="input100"
                                               placeholder="Número do documento de identificação" required />
                                    </div>
                                </div>
                                <div class="col-md">
                                    <div class="wrap-input100  bg1" data-validate="Informe uma data">
                                        <label asp-for="DataEmissaoDocumento" class="label-input100">
                                            Data de expedição <i class="fa fa-asterisk color-red"></i>
                                        </label>

                                        <input type="date" asp-for="DataEmissaoDocumento"
                                               class="input100 datetimepicker-input"
                                               placeholder="Selecione uma data" required />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mx-0 py-2 shadow-sm">
                            @* <---ESTUDANTE ---> *@
                            <div class="col-md-3">
                                <label>É estudante?</label>
                                <div class="toggle-checkbox checkbox-inline toggle-success toggle-sm"
                                     data-toggle="tooltip" title="Exibir/Não Exibir">
                                    <input type="checkbox" asp-for="IsEstudante">
                                    <label for="IsEstudante" style="margin: 0"></label>
                                </div>
                            </div>

                            @* <---DEFICIENCIA ---> *@
                            <div class="col-md-3">
                                <label>Possui deficiência?</label>
                                <div class="toggle-checkbox checkbox-inline toggle-success toggle-sm"
                                     data-toggle="tooltip" title="Exibir/Não Exibir">
                                    <input type="checkbox" asp-for="IsDeficiente">
                                    <label for="IsDeficiente" style="margin: 0"></label>
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="row">
                                <div class="col-md-6">
                                    @* <a>Voltar</a> *@
                                </div>
                                <div class="col-md-6 text-right">
                                    <a onclick="navigation(1,2)" class="btn bt-lg btn-primary w-100 text-white">Avançar ></a>
                                    @* <a onclick="navigation(2)" class="btn bt-lg btn-primary w-100 text-white">Avançar ></a> *@
                                </div>
                            </div>

                        </div>
                    </div>

                    @*<---ENDEREÇO---> *@
                    <div id="page-w-2" class="row mx-0 p-3 border shadow-sm rounded mt-5 bg-white" style="display: none">

                        <h3 class="text-center w-100 mb-3">ENDEREÇO</h3>

                        <div class="mx-0 px-0 row col-12">

                            @*<---CEP--->*@
                            <div class="col-12 col-md-4">
                                <div class="wrap-input100  bg1" data-validate="Digite o CEP">
                                    <label asp-for="Cep" class="label-input100">
                                        CEP <i class="fa fa-asterisk color-red"></i>
                                    </label>
                                    <input asp-for="Cep" id="Cep" class="input100"
                                           placeholder="Informe um cep" required />
                                </div>
                            </div>

                            @*<---CIDADE--->*@
                            <div class="col-12 col-md-4">
                                <div class="wrap-input100  bg1">
                                    <label asp-for="Cidade" class="label-input100">
                                        Cidade <i class="fa fa-asterisk color-red"></i>
                                    </label>
                                    <input asp-for="Cidade" id="Cidade" class="input100"
                                           placeholder="Digite uma cidade" required />
                                </div>
                            </div>

                            @*<---UF--->*@
                            <div class="col-12 col-md-4">
                                <div class="wrap-input100  bg1">
                                    <span class="label-input100">
                                        UF <i class="fa fa-asterisk color-red"></i>
                                    </span>
                                    <div>
                                        <select class="js-select2" asp-for="UF" id="UfOrgaoEmissor">
                                            <option value="AC">AC</option>
                                            <option value="AL">AL</option>
                                            <option value="AP">AP</option>
                                            <option value="AM">AM</option>
                                            <option value="BA">BA</option>
                                            <option value="CE">CE</option>
                                            <option value="DF">DF</option>
                                            <option value="ES">ES</option>
                                            <option value="GO">GO</option>
                                            <option value="MA">MA</option>
                                            <option value="MT">MT</option>
                                            <option value="MS">MS</option>
                                            <option value="MG">MG</option>
                                            <option value="PA">PA</option>
                                            <option value="PB">PB</option>
                                            <option value="PR">PR</option>
                                            <option value="PE">PE</option>
                                            <option value="PI">PI</option>
                                            <option value="RJ">RJ</option>
                                            <option value="RN">RN</option>
                                            <option value="RS">RS</option>
                                            <option value="RO">RO</option>
                                            <option value="RR">RR</option>
                                            <option value="SC">SC</option>
                                            <option value="SP">SP</option>
                                            <option value="SE">SE</option>
                                            <option value="TO" selected>TO</option>
                                        </select>
                                        <div class="dropDownSelect2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mx-0 px-0 row col-12">
                            @*<---LOGADOURO--->*@
                            <div class="col-12 col-md-8">

                                <div class="wrap-input100  bg1" data-validate="Informe seu nome">
                                    <label asp-for="Logradouro" class="label-input100">
                                        Logradouro
                                        <i class="fa fa-asterisk color-red"></i>
                                    </label>
                                    <input asp-for="Logradouro" id="Logradouro" class="input100"
                                           placeholder="Informe o logradouro" required />
                                </div>

                            </div>

                            @*<---NUMERO--->*@
                            <div class="col-12 col-md-4">
                                <div class="wrap-input100  bg1" data-validate="Nº da casa ou lote">
                                    <label asp-for="NumeroEndereco" class="label-input100">
                                        Número/Lote <i class="fa fa-asterisk color-red"></i>
                                    </label>
                                    <input asp-for="NumeroEndereco" id="NumeroEndereco" class="input100"
                                           placeholder="Digite o número" required />
                                </div>
                            </div>
                        </div>

                        <div class="mx-0 px-0 row col-12">

                            @*<---COMPLELEMNTO--->*@
                            <div class="col-12 col-md-8">
                                <div class="wrap-input100 bg1">
                                    <label asp-for="Complemento" class="label-input100">Complemento</label>
                                    <input asp-for="Complemento" id="Email" class="input100"
                                           placeholder="Digite um complemento (opcional)" />
                                </div>
                            </div>

                            @*<---BAIRRO--->*@
                            <div class="col-12 col-md ">
                                <div class="wrap-input100  bg1">
                                    <label asp-for="Bairro" class="label-input100">
                                        Bairro <i class="fa fa-asterisk color-red"></i>
                                    </label>
                                    <input asp-for="Bairro" id="Bairro" class="input100"
                                           placeholder="Digite um bairro" required />
                                </div>
                            </div>
                        </div>
                        <div class="row">



                            @if (cduotitul != null)
                            {
                                <div class="col-md-6">
                                    <a onclick="moveToPrevious(2,1)" class="btn bt-lg btn-secondary w-100 text-white"> Voltar</a>
                                </div>
                                <div class="col-md-6 text-right">
                                    <a onclick="navigation(2,4)" class="btn bt-lg btn-primary w-100 text-white">Avançar ></a>
                                </div>
                            }
                            else
                            {
                                
                            <div class="col-md-6">
                            <a onclick="moveToPrevious(2,1)" class="btn bt-lg btn-secondary w-100 text-white">Voltar</a>
                            </div>
                            <div class="col-md-6 text-right">
                            <a onclick="navigation(2,3)" class="btn bt-lg btn-primary w-100 text-white">Avançar ></a>
                            </div>
                            }


@* 
                            <div class="col-md-6">
                                <a onclick="moveToPrevious(2,1)" class="btn bt-lg btn-secondary w-100 text-white">< Voltar</a>
                            </div>
                            <div class="col-md-6 text-right">
                                <a onclick="navigation(2,3)" class="btn bt-lg btn-primary w-100 text-white">Avançar ></a>
                            </div> *@
                        </div>
                    </div>


                    @if (cduotitul == null)
                    {
                        @*<---DADOS DA EMPRESA---> *@
                        <div id="page-w-3" class="dados-empresa row mx-0 p-3 border shadow-sm rounded bg-white mt-5" style="display: none">

                            <h3 class="text-center w-100 mb-3">SITUAÇÃO PROFISSIONAL</h3>

                            <div class="mx-0 px-0 row col-12">

                                @*<---CNPJ--->*@
                                <div class="col-12 col-md-4">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="CnpjEmpresa" class="label-input100">
                                            CNPJ <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="CnpjEmpresa" id="CnpjEmpresa" class="input100 input-empresa" placeholder="Digite um CNPJ" required />
                                    </div>
                                </div>

                                @*<---RAZÃO SOCIAL--->*@
                                <div class="col-12 col-md">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="RazaoSocial"
                                               class="label-input100">
                                            Razão social <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="RazaoSocial" id="RazaoSocial"
                                               class="input100 input-empresa" placeholder="Digite uma razão social" required />
                                    </div>
                                </div>
                            </div>


                            <div class="mx-0 px-0 row col-12">

                                @*<---SITUAÇÃO PROFISSIONAL--->*@
                                <div class="col-12 col-md-4">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="IdSituacaoProfissional" class="label-input100">
                                            Situação profissional <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <select asp-for="IdSituacaoProfissional" asp-items="@ViewBag.IdSituacaoProfissional" class="js-select2" required>
                                            <option value="" selected>Selecione uma opção</option>
                                        </select>
                                        <div class="dropDownSelect2"></div>
                                    </div>
                                </div>

                                @*<---CARGO--->*@
                                <div class="col-12 col-md">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="Cargo" class="label-input100">
                                            Cargo <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="Cargo" id="Cargo"
                                               class="input100 input-empresa" placeholder="Digite um cargo" required />
                                    </div>
                                </div>
                            </div>


                            <div class="mx-0 px-0 row col-12">
                                @*<---DATA ADMISSÃO--->*@
                                <div class="col-12 col-md">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="DataAdmissao" class="label-input100">
                                            Data de admissão <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input type="date" asp-for="DataAdmissao"
                                               id="DataAdmissao" class="input100 datetimepicker-input input-empresa"
                                               placeholder="Selecione uma data de admissão" required />
                                    </div>
                                </div>

                                @*<---DATA DE DEMISSÃO--->*@
                                <div class="col-12 col-md">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="DataDemissao"
                                               class="label-input100">Data de demissão (caso exista)</label>
                                        <input type="date" asp-for="DataDemissao"
                                               id="DataDemissao" class="input100 datetimepicker-input"
                                               placeholder="Selecione uma data de demissão" />
                                    </div>
                                </div>
                            </div>

                            <div class="mx-0 px-0 row col-12">

                                @* <---NUMERO CARTEIRA--->*@
                                <div class="col-12 col-md-4">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="NumeroCarteiraProssional"
                                               class="label-input100">
                                            Nº da carteira de trabalho <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="NumeroCarteiraProssional"
                                               id="NumeroCarteiraProfissional" class="input100 input-empresa"
                                               placeholder="Digite o número da carteira ou contrato" required />
                                        <small>@ViewBag.Carteira</small>
                                    </div>
                                </div>

                                @* <---SERIE---> *@
                                <div class="col-12 col-md-4">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="SerieCtps" class="label-input100">
                                            Série <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="SerieCtps" id="Serie"
                                               class="input100 input-empresa" placeholder="Digite a série" required />
                                    </div>
                                </div>

                                @* <---PIS/ PASEP---> *@
                                <div class="col-12 col-md-4">
                                    <div class="wrap-input100  bg1">
                                        <label asp-for="PisPasep" class="label-input100">
                                            PIS/PASEP <i class="fa fa-asterisk color-red"></i>
                                        </label>
                                        <input asp-for="PisPasep" id="PisPasep" id="PisPasep"
                                               class="input100 input-empresa" placeholder="Digite o PIS/PASEP" required />
                                        <small>@ViewBag.PisPasep</small>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <a onclick="moveToPrevious(3,2)" class="btn bt-lg btn-secondary w-100 text-white"> Voltar</a>
                                </div>
