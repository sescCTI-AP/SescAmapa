@section Scripts
{
    <script src="~/js/SolicitacaoCadastro/wizard-navigation.js"></script>
    <script>

        $(document).ready(function () {

            //<--- AÇÕES AO CARREGAR E MASCARAS --->
            $('#loading').hide();   
            $('#Cep').mask('99999-999');
            $('#cpfDependente').mask('000.000.000-00');
            // $('#DataNascimento').mask('99/99/9999');
            $('#ComerciarioEmpresaPreCadastro_CnpjEmpresa').mask('00.000.000/0000-00');
            $('#PisPasep').mask('000.00000.00-0')
            $('#validacao').modal('show');
            var behavior = function (val) {
                return val.replace(/\D/g, '').length === 11 ? '(00) 00000-0000' : '(00) 0000-00009';
            },
                options = {
                    onKeyPress: function (val, e, field, options) {
                        field.mask(behavior.apply({}, arguments), options);
                    }
                };
            $('#Telefone').mask(behavior, options);

            //<--- AÇÕES RADIO TIPO CLIENTE --->
            $('.radio-group .radio-categoria').click(function () {
                var categoria = this.id;
                $('.selected .fa').removeClass('fa-check');
                $('.radio-categoria').removeClass('selected');
                $(this).addClass('selected');
                $('#form-dados').show();

                //<---COMERCIARIO--->
                if (categoria === 'categoria-comerciario') {
                    $('.dados-empresa').show();
                    var inputsEmpresa = document.querySelectorAll('.input-empresa');
                    inputsEmpresa.forEach(function (e) {
                        e.required = true;
                    });
                    $('#IdCategoria').val('1');
                    $('.anexo-empresa').addClass('anexo-obrigatorio')
                }
                //<---PUBLICO GERAL--->
                else {
                    $('.dados-empresa').hide();
                    var inputsEmpresa = document.querySelectorAll('.input-empresa');
                    inputsEmpresa.forEach(function (e) {
                        e.required = false;
                    });
                    $('#IdCategoria').val('2');
                    $('.anexo-empresa').removeClass('anexo-obrigatorio')
                }
            });
        });



        function navigation(idNow, idNext) {
            console.log(idNow + " -->" + idNext)
            validateAndMoveNext('page-w-' + idNow, 'page-w-' + idNext);
        }

        function moveToPrevious(currentPageId, nextPageId) {
            document.getElementById('page-w-' + currentPageId).style.display = 'none';
            document.getElementById('page-w-' + nextPageId).style.display = 'block';
        }


        // <--- VERIFICA SE JÁ EXISTE O NUMERO DE RG --->
        $('#NumeroDocumentoIdentificacao').focusout(function () {
            let docIdentificacao = $(this).val();
            $.ajax({
                url: '@Url.Action("VerificarDocIdentificacao", "Cliente", new { area = "Cliente" })/',
                type: "POST",
                data: { docIdentificacao: docIdentificacao },
                success: function (data) {
                    if (data.Code === 1) {
                        swal({
                            text: data.Message,
                            icon: data.ClassAlert,
                        })
                    }
                },
                error: function (err) {
                    alert('teste');
                }
            });
        });

        // <--- BUSCA SE JÁ EXISTE A EMPRESA PELO CNPJ --->
        $('#CnpjEmpresa').focusout(function () {
            let cnpj = $(this).val();
            $.ajax({
                url: '@Url.Action("GetDadosEmpresaByCnpj", "SolicitacaoCadastroCliente", new { area = "Cliente" })/',
                type: "POST",
                data: { cnpj: cnpj },
                success: function (data) {
                    console.log(data);

                    if (data.code === 1) {
                        $('#RazaoSocial').val(data.data.razaoSocial);
                    }
                    else {
                        swal({
                            text: data.Message,
                            icon: data.ClassAlert,
                        })
                    }
                },
                error: function (err) {
                    alert(err);
                }
            });
        });

        $('#Cep').focusout(function () {
            let cep = $(this).val();
            $.ajax({
                url: '/cadastro/busca-cep/' + cep,
                type: "GET",
                success: function (data) {
                    console.log(data);

                    if (data.code === 1) {
                        $('#Cidade').val(data.data.siafi);
                        $('#Dscidade').val(data.data.localidade);
                        $('#UF').val(data.data.uf);
                        $('#Logradouro').val(data.data.logradouro);
                        $('#Bairro').val(data.data.bairro);
                        //$('#').val(data.data.razaoSocial);
                    }
                    else {
                        swal({
                            text: data.Message,
                            icon: data.ClassAlert,
                        })
                    }
                },
                error: function (err) {
                    console.log(err);
                    alert("Cep não encontrado");
                }
            });
        });

        // <--- BUSCA SE JÁ EXISTE PIS/PASEP --->
        // $('#PisPasep').focusout(function () {
        //     let pis = $(this).val();
        //     $.ajax({
        //         url: '@Url.Action("VerificaPisPasep", "Cliente", new { area = "Cliente" })/',
        //         type: "POST",
        //         data: { pis: pis },
        //         success: function (data) {
        //             if (data.Code === 2) {
        //                 swal({
        //                     text: data.Message,
        //                     icon: data.ClassAlert,
        //                 })
        //             }
        //         },
        //         error: function (err) {
        //             alert('teste11111');
        //         }
        //     });
        // });

        document.getElementById("formAlteracaoClienteComerciario").addEventListener("submit", function (event) {
            $('#loading').show();
        });



        function mascaraMoeda(campo, evento) {
            var tecla = (!evento) ? window.event.keyCode : evento.which;
            var valor = campo.value.replace(/[^\d]+/gi, '').reverse();
            var resultado = "";
            var mascara = "##.###.###,##".reverse();
            for (var x = 0, y = 0; x < mascara.length && y < valor.length;) {
                if (mascara.charAt(x) != '#') {
                    resultado += mascara.charAt(x);
                    x++;
                } else {
                    resultado += valor.charAt(y);
                    y++;
                    x++;
                }
            }
            campo.value = resultado.reverse();
        }

        //<--- AO SUBMETER FORMULARIO --->
        onSend = function (xhr) {

            $.LoadingOverlay("show",
                {
                    background: "rgba(176, 177, 178, 0.5)",
                    text: "Aguarde..."
                });
        };

        //<--- SUBMISSÃO COMPLETA --->
        completed = function (xhr) {
            $.LoadingOverlay("hide");
            console.log(xhr);
            if (xhr.responseJSON.Code === 1) {
                swal({
                    text: xhr.responseJSON.Message,
                    icon: xhr.responseJSON.ClassAlert,
                }).then(function () {
                    window.location = `@Url.Action("Dashboard", "Cliente", new
            { area = "Cliente" })`
                });
            }
            else {
                swal({
                    text: xhr.responseJSON.Message,
                    icon: xhr.responseJSON.ClassAlert,
                })
            }
        };

        error = function (xhr) {
            $.LoadingOverlay("hide");
            swal({
                text: xhr.responseJSON.Message,
                icon: xhr.responseJSON.ClassAlert,
            });
        };


        //<--- ANEXO CHANGE --->
        $('.anexo-inputs').change(function () {
            const anexoFile = $(this).get(0).files;
            if (anexoFile.length > 0) {
                getBase64(anexoFile[0])
                    .then(data => {
                        if ($(this).attr('id') === 'FotoPerfil') {
                            return $('#div-foto-perfil').css('background-image', `url(${data})`)
                        }
                        $(this).next('.preview-img').attr('src', `${data}`)
                            .next('.descricao-anexo').html(anexoFile[0].name)

                        if ($(this).siblings('.erro-anexo').is(':visible')) {
                            $(this).siblings('.erro-anexo').addClass('d-none')
                        }
                    });
            }
        })

        document.addEventListener('input', function (event) {
            if (event.target.tagName === 'INPUT' && event.target.type === 'text') {
                event.target.value = event.target.value.toUpperCase();
            }
        });

        String.prototype.reverse = function () {
            return this.split('').reverse().join('');
        };

        function getBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
            });
        }

    </script>

