@model SiteSesc.Models.Area

@{
}
<link href="~/js/croppie/croppie.min.css" rel="stylesheet" />
<link href="~/css/summernote/summernote-bs4.css" rel="stylesheet" />

<h4>Area</h4>
<hr />
<div class="row">

    <form asp-action="EditPost">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-group">
            <label for="nome" class="control-label">Nome</label>
            <input id="nome" name="nome" class="form-control" value="@Model.Nome"/>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Descricao)
            @Html.TextAreaFor(model => model.Descricao, new { @class = "form-control", @row = 5 })
            @Html.ValidationMessageFor(model => model.Descricao, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mt-3" >
        <a asp-action="Index" class="btn btn-danger">Voltar</a>
            <input type="submit" value="Salvar" class="btn btn-primary" />

        </div>
    </form>
</div>

<div class="p-3">
    <a onclick="exibeCrop();" class="btn btn-secondary mb-3">Alterar foto</a>
    @if (Model.Arquivo != null)
    {
        <img class="card-img-top p-0" src="@Model.Arquivo.CaminhoVirtualFormatado()" alt="Imagem da notícia" style="padding: 0 15px;">
    }
    <div id="div-crop-image" class="row mt-3">
        <form asp-action="Anexar" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="imagemRecortada" id="imagemRecortada" />

            <div class="form-group mb-3 crop-area">
                <label for="upload" role="button" class="btn btn-info">Selecionar Imagem</label>
                <input data-val="true" data-val-required="Arquivo" id="upload" name="upload" type="file" style="display: none" accept=".jpg, .jpeg, .png">
                <button type="button" class="btn btn-success" id="btnCortarImagem" disabled>
                    <span class="fa fa-scissors"></span> Cortar Imagem
                </button>
                <p class="text-primary mb-0 mt-2">Obs.: Selecione uma imagem, ajuste o enquadramento e depois clique em Cortar imagem.</p>
                <p class="text-danger">Para melhor enquadramento utilizar imagens na resolução <b>1600 x 670px.</b></p>
            </div>
            <div class="row">
                <div class="col-md-8 crop-area">
                    <div id="croppingArea"></div>
                </div>
                <div class="col-md">
                    <div id="resultCrop"></div>
                    <div id="resultado" class="mt-3"></div>
                        <input type="submit" value="Salvar imagem" class="btn btn-success" />
                    
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/croppie/croppie.min.js"></script>
    <script src="~/js/croppie/exif.min.js"></script>
    <script src="~/js/banner/cropbanner.js"></script>
    <script src="~/js/summernote/summernote-bs4.js"></script>
    <script src="~/js/summernote/summernote-pt-br.js"></script>

    <script>
        $('#div-crop-image').hide();
        $('#resultado').hide();


        function exibeCrop(){
            $('#div-crop-image').show();
        }
        $(document).ready(function () {
            $('#Descricao').summernote({
                fontStyle: {
                    foreColor: 'black'
                },
                height: 500,
                lang: 'pt-BR',
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['font', ['strikethrough', 'superscript', 'subscript']],
                    ['fontsize', ['fontsize']],
                    ['color', ['color']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['height', ['height']]
                ]
            });
            $('#Descricao').summernote('foreColor', 'black');
        });

        $('.showPreviewImagemUpload').change(function () {
            if (typeof (FileReader) !== 'undefined') {

                var imageHolder = $('#image-holder');
                console.log(divcrop);
                imageHolder.empty();

                const reader = new FileReader();
                reader.onload = function (e) {
                    $("<img />",
                        {
                            "src": e.target.result,
                            "style": "height: 300px",
                            "class": "thumb-image"
                        }).appendTo(imageHolder);
                }
                imageHolder.show();
                reader.readAsDataURL($(this)[0].files[0]);
            } else {
                alert("Este navegador nao suporta FileReader.");
            }
        });
    </script>
}
