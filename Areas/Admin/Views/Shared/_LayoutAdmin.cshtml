@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Security.Claims;
@inject Microsoft.AspNetCore.Mvc.ViewComponents.IViewComponentSelector selector
@{
    var usuarioLogado = User.Identity.Name;
    var perfil = "";
    var tema = "";
    var areaName = ViewContext.RouteData.Values["area"].ToString();

    if (((ClaimsIdentity)User.Identity).HasClaim(c => c.Type == "Perfil"))
    {
        perfil = ((ClaimsIdentity)User.Identity).FindFirst("Perfil").Value;
    }

    if (((ClaimsIdentity)User.Identity).HasClaim(c => c.Type == "TemaEscuro"))
    {
        tema = ((ClaimsIdentity)User.Identity).FindFirst("TemaEscuro").Value;
    }

    var classesAdministrativas = "";
    if (areaName == "Admin") { classesAdministrativas = "p-3 shadow-sm rounded border"; }
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Sesc @Configuration["Ambiente:UF"]</title>
    <!-- Favicons -->
    <link href="~/images/static/logo-mini.png" rel="icon">
    <link href="~/images/static/logo-mini.png" rel="apple-touch-icon">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SiteSesc.styles.css" asp-append-version="true" />
    <link href="~/css/espacocliente/aos/aos.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/css/espacocliente/boxicons/css/boxicons.min.css" rel="stylesheet" />
    <link href="~/css/espacocliente/glightbox/css/glightbox.min.css" rel="stylesheet" />
    <link href="~/css/espacocliente/swiper/swiper-bundle.min.css" rel="stylesheet" />
    <link href="~/css/espacocliente/style.css" rel="stylesheet" />
    <link href="~/css/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/izitoast.css" rel="stylesheet" />
    <link href="~/css/3th/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />
    <script src="~/js/util.js"></script>
    <link href="~/css/toggle.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Raleway:300,300i,400,400i,500,500i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i" rel="stylesheet">
</head>

<link href="~/css/layoutadmin/layout.css" rel="stylesheet" />
<link href="~/css/espacocliente/switch.css" rel="stylesheet" />
<link href="~/css/scrollbar.css" rel="stylesheet" />


<body>
    @await Component.InvokeAsync("SideMenu", "admin")

    <div class="container">
        <div style="text-align: left; padding-top: 15px">
            <a id="btn-switch" class="btn btn-sm btn-outline-primary button-rounded btn-auto"><i class="fa-solid fa-user"></i> &nbsp;Espaço do cliente</a>
            <span class="font-size-24" style="margin-left: 20px">Espaço Administrativo</span>
        </div>
        <div class="container pt-5">            
            <div class="card">
                <div class="card-body">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("PartialView/_PartialViewImage")
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/jquery-validation/dist/additional-methods.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/css/espacocliente/purecounter/purecounter_vanilla.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/css/espacocliente/glightbox/js/glightbox.min.js"></script>
    <script src="~/css/espacocliente/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/css/espacocliente/swiper/swiper-bundle.min.js"></script>
    <script src="~/css/espacocliente/typed.js/typed.umd.js"></script>
    <script src="~/css/espacocliente/waypoints/noframework.waypoints.js"></script>
   <script src="~/js/espacocliente/main.js"></script>
    <script src="~/js/fontawesome6.js"></script>
    <script src="~/js/izitoast.js"></script>
    <script src="~/js/3th/sweetalert.min.js"></script>

    <script src="~/js/3th/jquery.mask.min.js"></script>

    <script src="~/js/3th/moment.min.js"></script>
    <script src="~/js/3th/moment-pt-br.js"></script>
    <script src="~/js/3th/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/js/3th/jquery.maskMoney.min.js"></script>
    <script src="~/js/3th/loadingoverlay.min.js"></script>
    <script src="~/js/3th/jquery.noty.packaged.min.js"></script>
    <script src="~/js/3th/datatables/jquery.dataTables.min.js"></script>
    <script src="~/js/3th/datatables/dataTables.bootstrap4.min.js"></script>
    @* <script src="~/js/shared/layout-logged.js"></script> *@

    <script>
        document.getElementById('btn-switch').addEventListener('click', function (e) {
            window.location.href = "/cliente";
        });

        function definirTelaInicial(rota) {
            fetch('/admin/tela-inicial?rota=' + rota)
                .then(response => response.json())
                .then(data => {
                    iziToast.success({
                        title: 'Sucesso',
                        message: "Tela incial definida",
                        theme: 'light',
                        position: 'topRight',
                    });
                })
                .catch(error => {
                    console.error('Erro ao definir tela incial:', error);
                });
        }

    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
