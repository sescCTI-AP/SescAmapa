    {
        <a asp-action="SolicitacaoCadastroCliente" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-idStatus="@idStatus">Próximo</a>
    }
</div> *@

@section Scripts {
    <script src="~/js/3th/datatables/jquery.dataTables.min.js"></script>
    <script src="~/js/3th/datatables/dataTables.buttons.min.js"></script>
    <script src="~/js/3th/datatables/pdfmake.min.js"></script>
    <script src="~/js/3th/datatables/jszip.min.js"></script>
    <script src="~/js/3th/datatables/vfs_fonts.js"></script>
    <script src="~/js/3th/datatables/buttons.flash.min.js"></script>
    <script src="~/js/3th/datatables/buttons.html5.min.js"></script>
    <script src="~/js/3th/datatables/buttons.print.min.js"></script>
    <script>
        $(document).ready(function () {
            console.log("teste");
            $('#tblSolicitacao').DataTable({
                pageLength: 50,
                lengthChange: false,
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.10.19/i18n/Portuguese-Brasil.json"
                },
                info: true,
                ordering: true,
                dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'excel',
                        exportOptions: {
                            columns: ':not(:last-child)' // Exclui a última coluna (onde está o link de edição)
                        }
                    }
                ]
            });
        });
    </script>
}