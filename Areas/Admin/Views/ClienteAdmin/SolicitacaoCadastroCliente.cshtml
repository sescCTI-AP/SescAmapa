    @for (var i = 1; i <= Model.TotalPages; i++)
    {
        <a asp-action="SolicitacaoCadastroCliente" asp-route-pageNumber="@i" class="@(i == Model.PageIndex ? "active" : "")" asp-route-idStatus="@idStatus">@i</a>
