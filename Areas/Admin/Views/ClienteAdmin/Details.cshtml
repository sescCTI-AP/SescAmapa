        document.getElementById('validateButton').addEventListener('click', async function (event) {
            event.preventDefault();
            console.log('Id: ' + '@Model.Id');
            const url = '/admin/clientes/add/' + '@Model.Id';
            var botao = document.getElementById('validateButton');
            botao.innerHTML = "";
            var imagem = document.createElement('img');
            imagem.src = '../../../../images/static/loading.gif';
            imagem.width = 40;
            imagem.width = 40;
            imagem.height = 40;
            botao.appendChild(imagem);
            botao.classList.add('disabled');
            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                if (!response.ok) {
                    botao.innerHTML = "Enviar";
                    botao.classList.remove('disabled');
                    throw new Error('Network response was not ok');
                }
                console.log(response);

                window.location.href = '/admin/clientes/soliticacoes-cadastro';

            } catch (error) {
                console.error('There was a problem with the fetch operation:', error);
                botao.innerHTML = "Enviar";
                botao.classList.remove('disabled');
            }
        });

        function modalConfirmacao() {
            $('#confirmationModal').modal('show'); // Abre o modal
        }

        function mostraTabelaMensagem() {
            var display = document.getElementById('table-Messagem').style.display;
            if (display == "none")
                document.getElementById('table-Messagem').style.display = 'block';
            else
                document.getElementById('table-Messagem').style.display = 'none';
        }

        function selecionarMensagem(descricao) {
            document.getElementById('observacao').value = descricao;
            document.getElementById('table-Messagem').style.display = 'none';
        }

        // document.getElementById("btn-validar").addEventListener("click", function (event) {
        //     $('#loading').show();
        // });

        function enviaCorrecao(Id) {

            var botao = document.getElementById('btn-enviar');
            botao.innerHTML = "";
            var imagem = document.createElement('img');
            imagem.src = '../../../../images/static/loading.gif';
            imagem.width = 40;
            imagem.width = 40;
            imagem.height = 40;
            botao.appendChild(imagem);
            botao.classList.add('disabled');

            $.ajax({
                url: '@Url.Action("EnviaCorrecao", "ClienteAdmin")',
                type: 'POST',
                data: {
                    Id: Id,
                    msg: $('#observacao').val()
                },
                success: function (response) {
                    if (response.code == 1) {
                        $('#observacao').val('');
                        $('#modalInvalidarCadastro').modal('hide');
                        $('#timeline').load(location.href + ' #timeline>*',
                            function () {
                                $('[data-toggle="tooltip"]').tooltip();
                            });
                        iziToast.success({
                            title: 'Sucesso',
                            message: response.msg,
                            theme: 'light',
                            position: 'topRight',
                        });
                        botao.innerHTML = "Enviar";
                        botao.classList.remove('disabled');
                    }
                    if (response.code == 0) {
                        iziToast.error({
                            title: 'Erro',
                            message: response.msg,
                            theme: 'light',
                            position: 'topRight',
                        });
                    }
                },
                error: function (error) {
                    console.error(error);
                }
            });
        }
    </script>
}