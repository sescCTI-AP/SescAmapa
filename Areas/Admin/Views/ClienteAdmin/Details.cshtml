                        @Html.DisplayNameFor(model => model.DataSolicitacao)
                    </dt>
                    <dd class="col-sm-12">
                        @Html.DisplayFor(model => model.DataSolicitacao)
                    </dd>
                </dl>
                <dl class="col-md">
                    <dt class="col-sm-12">
                        @Html.DisplayNameFor(model => model.Status)
                    </dt>
                    <dd class="col-sm-12">
                        @Html.DisplayFor(model => model.Status.Nome)
                    </dd>
                </dl>
            </div>


            <div class="accordion" id="accordionExample">
