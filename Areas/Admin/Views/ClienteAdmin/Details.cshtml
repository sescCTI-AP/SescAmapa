                                <dt class="col-sm-4">
                                    @Html.DisplayNameFor(model => model.RendaFamiliar)
                                </dt>
                                <dd class="col-sm-8">
                                    @Model.RendaFamiliar.ToString("C")
                                </dd>
                                <dt class="col-sm-4">
                                    @Html.DisplayNameFor(model => model.IsEstudante)
                                </dt>
                                <dd class="col-sm-8">
                                    @Html.DisplayBoolAsText(Model.IsEstudante)
                                </dd>
                                <dt class="col-sm-4">
                                    @Html.DisplayNameFor(model => model.IsDependente)
                                </dt>
                                <dd class="col-sm-8">
                                    @Html.DisplayBoolAsText(Model.IsDependente)
