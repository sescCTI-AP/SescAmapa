@model SiteSesc.Models.SolicitacaoCadastroCliente
@using SiteSesc.Models.ApiPagamento
@{
    var arquivos = ViewBag.Arquivos as List<ArquivoCadastroCliente>;
    var msgRapidas = ViewBag.MsgRapidas as List<MensagemRapida>;
    var historico = ViewBag.Historico as List<HstSolicitacao>;
    var dirHst = "";
    var titular = ViewBag.Titular as CLIENTELA;
}
<link rel="stylesheet" href="~/css/solicitacaocadastro/novocadastro.css" asp-append-version="true" />
<link href="~/css/solicitacaocadastro/acompanhamento.css" rel="stylesheet" />
<style>
    #loading {
        display: none; /* Esconda por padrão */
        position: fixed;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div id="loading" class="loading-gif">
    <img src="~/images/loading.gif" alt="Loading">
</div>


<div class="mt-4">
    <div class="row">
        <div class="col-md">
            <p>@ViewBag.Validacao</p>
            <h4>Solicitação de Cadastro de Cliente</h4>
        </div>
        <div class="col-md">
            <h3 style="text-transform: uppercase; text-align: right!important; color: dodgerblue; font-style: italic; font-weight: bold">CLIENTE @Html.DisplayFor(model => model.TipoCategoria)</h3>
            @if (Model.Cduotitul != null)
            {
                <h3 style="text-transform: uppercase; text-align: right!important; color: orange; font-style: italic; font-weight: bold">SOLICITAÇÃO DE DEPENDENTE</h3>
            }
        </div>
    </div>
    <div class="ctn-fluid fluid-end">
       @*  @if (Model.IdStatus <= 4)
        {
            @if (Model.TipoCategoria != "renovacao")
            { *@
        @if (Model.Status != null && Model.Status.Id != 5) // Supondo que 'Id' é a propriedade que contém o valor 5
        {
            <div>
                <a onclick="modalConfirmacao();" class="btn btn-outline-success button-rounded m-2">Validar</a>

                </div>}
           @*  } *@

            <div>
                <a class="btn btn-outline-danger button-rounded m-2" data-bs-toggle="modal" data-bs-target="#modalInvalidarCadastro">Adicionar interação</a>
            </div>
        @if (Model.Status != null && Model.Status.Id != 5) // Supondo que 'Id' é a propriedade que contém o valor 5
        {
            <div>
                <a class="btn btn-outline-dark button-rounded m-2" data-bs-toggle="modal" data-bs-target="#modalConfirmaFinalizacao">Encerrar</a>
            </div>
        }
       @*  } *@

        <div>
            <a class="btn btn-outline-primary button-rounded m-2" href="#" onclick="window.print();">Imprimir</a>
        </div>
    </div>
    <hr />

    <div class="row">
        <div class="col-md-4">
            @if (arquivos != null)
            {
                if (arquivos.Any(a => a.Tipo == "FotoPerfil"))
                {
                    <p>Foto de perfil</p>
                    <img class="img-thumbnail w-300 border-radius-20" src="@arquivos.FirstOrDefault(a => a.Tipo == "FotoPerfil").Arquivo.CaminhoVirtualFormatado()" />
                }
            }
            <p class="mt-5 mb-0">Arquivos enviados:</p>
            <div class="ctn-fluid fluid-start">
                @foreach (var arquivo in arquivos.Where(a => a.Tipo != "FotoPerfil"))
                {
                    <div>
                        <input id="caminho-@arquivo.Arquivo.Id" hidden value="@arquivo.Arquivo.CaminhoVirtualFormatado()" />
                        <img class="img-thumbnail" style="cursor: pointer" src="@arquivo.Arquivo.CaminhoVirtualFormatado()" onclick="imageZoom('@arquivo.Arquivo.Id')" />
                        <br /><span style="font-size: 10px">@arquivo.Tipo</span>
                    </div>
                }
            </div>
        </div>
        <div class="col-md">
            @if (titular != null)
            {
                <h4><b>Dados do titular</b></h4>
                <dl class="row">
                    <dt class="col-sm-4">
                        Nome:
                    </dt>
                    <dd class="col-sm-8">
                        @titular.NMCLIENTE.Trim()
                    </dd>
                    <dt class="col-sm-4">
                        CPF do titular:
                    </dt>
                    <dd class="col-sm-8">
                        @titular.NUCPF.Trim()
                    </dd>
                </dl>
