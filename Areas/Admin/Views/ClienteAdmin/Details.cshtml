    <div id="timeline" class="mt-5">
        <h4 class="text-gray">Timeline da solicitação</h4>
        <div class="card card-dados-cliente">
            <div class="card-body">
                <div class="col-md-12">
                    @if (historico != null)
                    {
                        <ul class="sem-marcador">
                            @foreach (var hst in historico)
                            {
                                <li>
                                    <div class="container py-2">
                                        <div class="row">
                                            @if (hst.IsCliente)
                                            {
                                                <div class="col-auto text-center flex-column d-none d-sm-flex">
                                                    <small class="m-2">
                                                        @if (arquivos.Any())
                                                        {
                                                            <img src="@arquivos.FirstOrDefault(a => a.Tipo == "FotoPerfil").Arquivo.CaminhoVirtualFormatado()" class="img-avatar" />

                                                        }
                                                        <h6>Cliente</h6>
                                                    </small>
                                                </div>
                                                <div class="col py-2 flex-container">
                                                    <div class="ctn-fluid fluid-start">
                                                        <div class="triangulo-para-esq"></div>
                                                        <div class="card card-timeline card-esq">
                                                            <div class="card-body">
                                                                <h6 class="card-title">
                                                                    @hst.Observacao
                                                                </h6>
                                                                <div class="float-right text-right font-italic font-size-small">
                                                                    @hst.Usuario.Nome <br>em @hst.DataCadastro
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                </div>
                                            }
                                            else
                                            {
                                                <div class="col py-2 flex-container">
                                                    <div class="ctn-fluid fluid-start">
                                                        <div class="card card-timeline card-dir">
                                                            <div class="card-body">
                                                                <h6 class="card-title">
                                                                    @hst.Observacao
                                                                </h6>
                                                                <div class="float-right text-right font-italic font-size-small">
                                                                    @hst.Usuario.Nome <br> em @hst.DataCadastro
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="triangulo-para-dir"></div>
                                                    </div>
                                                </div>
                                                <div class="col-auto text-center flex-column d-none d-sm-flex">
                                                    <small class="m-2">
                                                        <img src="~/images/static/logo-mini-alpha.png" class="img-avatar" />
                                                        <h6>Atendente</h6>
                                                    </small>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<div>  
    <a href="/admin/clientes/soliticacoes-cadastro">Voltar</a>



</div>


<div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmationModalLabel">Confirmação</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Você realmente deseja confirmar o cadastro do cliente?
            </div>
            <div class="modal-footer">
                <a type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</a>
                @* <a href="@Url.Action("AddCliente","ClienteAdmin", new{id = Model.Id})" class="btn btn-success">Validar</a> *@
                <a id="validateButton" class="btn btn-success">Validar</a>

            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalConfirmaFinalizacao" tabindex="-1" role="dialog" aria-labelledby="modalValidarCadastro-label">
    <div class="modal-dialog " role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="modalConfirmaFinalizacao-label">Encerrar cadastro</h4>
                <button type="button" class="close btn btn-danger" data-bs-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <h3 class="text-center">Você realmente deseja encerrar a solicitação? <br /><br />Não será possível retomar a mesma.</h3>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger button-rounded" data-bs-dismiss="modal">Cancelar</button>
                <a class="btn btn-outline-success button-rounded" asp-action="Finalizar" asp-controller="ClienteAdmin" asp-route-idSolicitacao="@Model.Id">Confirmar</a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalInvalidarCadastro" tabindex="-1" role="dialog" aria-labelledby="modalValidarCadastro-label">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Informe as alterações que o usuário deve realizar</h4>
                <button type="button" class="close btn btn-danger" data-bs-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>OBSERVAÇÃO</label>
                    <textarea rows="3" class="form-control" id="observacao"></textarea>
                    <button type="button" class="rounded-circle btn text-yellow" id="listarMensagensRapidas" onclick="mostraTabelaMensagem()">
                        <i class="fa fa-bolt fa-2x" aria-hidden="true"></i>
                    </button>
                </div>
                <div id="table-Messagem">
                    <div class="form-group" id="divTableMensagem">

                        @foreach (var item in msgRapidas)
                        {
                            <div class="card mt-1 cursor-pointer" style="border-radius: 0px">
                                <div class="card-body">
                                    <a onclick="selecionarMensagem(`@item.Descricao`)" class="text-black">@item.Descricao</a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger button-rounded" data-bs-dismiss="modal">Cancelar</button>
                <button id="btn-enviar" type="button" class="btn btn-success button-rounded" onclick="enviaCorrecao('@Model.Id')">Enviar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#loading').hide();

            document.getElementById('table-Messagem').style.display = 'none';

        });
