                                <dd class="col-sm-8">
                                    @Html.DisplayFor(model => model.TelefonePrimario)
                                </dd>
                                @if (Model.TelefoneSecundario != null)
                                {
                                    <dt class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.TelefoneSecundario)
                                    </dt>
                                    <dd class="col-sm-8">
                                        @Html.DisplayFor(model => model.TelefoneSecundario)
                                    </dd>
                                }
                            </dl>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingTwo">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                            Documentação
                        </button>
                    </h2>
                    <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#accordionExample">
                        <div class="accordion-body">
                            <dl class="row">
                                <dt class="col-sm-4">
                                    @Html.DisplayNameFor(model => model.Usuario.Cpf)
                                </dt>
                                <dd class="col-sm-8">
                                    @Html.DisplayFor(model => model.Usuario.Cpf)
                                </dd>
                                <dt class="col-sm-4">
                                    Documento de identificação
                                </dt>
                                <dd class="col-sm-8">
                                    @Html.DisplayFor(model => model.NumeroDocumento)
                                </dd>
                                <dt class="col-sm-4">
                                    @Html.DisplayNameFor(model => model.OrgaoEmissor)
                                </dt>
                                <dd class="col-sm-8">
                                    @Html.DisplayFor(model => model.OrgaoEmissor)
