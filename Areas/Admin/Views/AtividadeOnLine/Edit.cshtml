@model SiteSesc.Models.Atividade.AtividadeOnLine
@using SiteSesc.Models.ApiPagamento
@{
    ViewBag.Title = "Atividades OnLine";
    var atividadeCentral = ViewBag.AtividadeCentral as AtividadeApi;
}

<link href="~/css/3th/summernote/summernote-bs4.css" rel="stylesheet" />
<link href="~/js/3th/croppie/croppie.min.css" rel="stylesheet" />
<style>
    .cr-boundary {
        margin: 0 !important;
    }

    .cr-slider-wrap {
        margin: 15px 0 !important;
        padding: 0 !important;
    }

    label {
        font-size: 12px
    }

    .note-popover .popover-content, .card-header.note-toolbar {
        border-radius: 20px;
    }

    .note-resizebar {
        display: none
    }
</style>

    <h3 style="text-transform: uppercase; font-weight: bold">@Model.NomeExibicao</h3>
<div class="card">

    <div class="card-body">
        <h5 class="font-size-12"><b>DADOS DA ATIVIDADE NA CENTRAL</b></h5>
        <input id="CdPrograma" name="CdPrograma" value="@atividadeCentral.cdprograma" hidden />
        <input id="CdConfig" name="CdConfig" value="@atividadeCentral.cdconfig" hidden />
        <input id="SqOcorrenc" name="SqOcorrenc" value="@atividadeCentral.sqocorrenc" hidden />

        <div class="form-group">
            <label>NOME NA CENTRAL</label>
            <input class="form-control" value="@atividadeCentral.dsusuario" readonly />
        </div>
        <div class="row mt-3">
            <div class="col-md">
                <div class="form-group">
                    <label>VAGAS TOTAIS</label>
                    <input class="form-control" value="@atividadeCentral.nuvagas" readonly />
                </div>
            </div>
            <div class="col-md">
                <div class="form-group">
                    <label>DATA DE INÍCIO DA ATIVIDADE</label>
                    <input class="form-control" value="@atividadeCentral.dtiniocorr?.ToShortDateString()" readonly />
                </div>
            </div>
            <div class="col-md">
                <div class="form-group">
                    <label>DATA FINAL DA ATIVIDADE</label>
                    <input class="form-control" value="@atividadeCentral.dtfimocorr?.ToShortDateString()" readonly />
                </div>
            </div>
            <div class="col-md">
                <div class="form-group">
                    <label>DATA DE INÍCIO DAS INCRIÇÕES</label>
                    <input class="form-control" value="@atividadeCentral.dtlinscri?.ToShortDateString()" readonly />
                </div>
            </div>
            <div class="col-md">
                <div class="form-group">
                    <label>DATA FINAL DAS INSCRIÇÕES</label>
                    <input class="form-control" value="@atividadeCentral.dtuinscri?.ToShortDateString()" readonly />
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card-block">
    @if (!string.IsNullOrEmpty(ViewBag.Validacao))
    {
        <p class="text-danger text-center">@ViewBag.Validacao</p>
    }
    @using (Html.BeginForm("Edit", "AtividadeOnLine", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.Id)
        @Html.HiddenFor(model => model.IdUnidadeOperacional)
        @Html.HiddenFor(model => model.IdArquivo)
        @Html.HiddenFor(model => model.DataInicio)
        @Html.HiddenFor(model => model.DataFim)
        @Html.HiddenFor(model => model.HoraInicio)
        @Html.HiddenFor(model => model.HoraFim)
        @Html.HiddenFor(model => model.Cdprograma)
        @Html.HiddenFor(model => model.Cdconfig)
        @Html.HiddenFor(model => model.Sqocorrenc)
        @Html.HiddenFor(model => model.Ano)
        <input type="hidden" name="imagemRecortada" id="imagemRecortada" />

        @if (Model.IdArquivo != null)
        {
            <input type="hidden" id="imagemNoticiatual" value="@Model.Arquivo.CaminhoVirtualFormatado" />
        }
        <div class="form-group mt-3">
            <label>NOME DE EXIBIÇÃO</label>
            @Html.EditorFor(model => model.NomeExibicao, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.NomeExibicao, "", new { @class = "text-danger" })
        </div>
        <div class="form-group mt-3">
            <label>DESCRIÇÃO</label>
            @Html.TextAreaFor(model => model.Descricao, new { @class = "form-control", @row = 5 })
            @Html.ValidationMessageFor(model => model.Descricao, "", new { @class = "text-danger" })
        </div>
        <div class="row">
            <div class="col-md">
                <div class="form-group">
                    <div class="row">
                        <div class="col">
                            @Html.LabelFor(model => model.SubArea)
                            @Html.DropDownList("IdSubArea", null, null, new { @class = "form-control", @style = "overflow: hidden" })
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <label><b>OPÇÕES</b></label>
            <div>
                @Html.CheckBoxFor(m => m.IsOnline)
                <label asp-for="IsOnline" for="IsOnline">Inscrição on-line?</label>
            </div>
            <div>
                @Html.CheckBoxFor(m => m.IsGratuito)
                <label asp-for="IsGratuito" for="IsGratuito">Atividade gratuita?</label>
            </div>
            <div>
                @Html.CheckBoxFor(m => m.DescontoPontualidade)
                <label asp-for="DescontoPontualidade" for="DescontoPontualidade">Desconto de pontualidade</label>
            </div>
        </div>

        

        <div id="div-foto-atual" class="col text-center mt-5">
            <hr />
            <h4 class="col-12 text-center">Imagem atual</h4>
            <button type="button" class="btn-rounded bg-transaparent pb-0 pt-0 mb-1" onclick="exibirAlteradorFoto()">Alterar Foto</button>
            <div class="col-12">
                @if (Model.Arquivo != null)
                {
                    <img src="@Model.Arquivo.CaminhoVirtualFormatado()" />
                }
            </div>
        </div>

        <div id="div-alteracao-foto" class="form-group">
            <div class="form-group mt-5">
                <label class="font-size-18"><b>SELECIONAR UMA IMAGEM PARA CAPA DA ATIVIDADE</b></label>
                <label for="upload" role="button" class="btn-rounded bg-blue"><span class="fa-solid fa-image fa-2x"></span> <span class="font-size-16">&nbsp;Selecionar Imagem</span></label>
                <input data-val="true" data-val-required="Arquivo" id="upload" name="upload" type="file" style="display: none" accept=".jpg, .jpeg, .png">
                <button type="button" class="btn-rounded bg-transaparent bg-blue" id="btnCortarImagem" disabled>
                    <span class="fa fa-scissors"></span> Cortar Imagem
                </button>
                <a onclick="exibeImagemAtual();" type="button" class="btn-rounded bg-transparent btn-cancel text-center">
                    <span class="fa fa-remove"></span> Cancelar
                </a>
                <p class="text-primary mb-0 mt-2">Obs.: Selecione uma imagem, ajuste o enquadramento e depois clique em Cortar imagem.</p>

            </div>
            <div class="row">
                <div id="cropp-remove" class="col-md-8">
                    <div id="croppingArea"></div>
                </div>
                <div class="col-md text-center">
                    <div id="resultCrop"></div>
                </div>
            </div>
        </div>
@* 
        <div class="form-group" style="margin-bottom: 0">
            <input type="submit" value="Salvar" class="btn btn-info" />
            <a href="@Url.Action("Index")" class="btn btn-default">Voltar</a>
        </div> *@

        <div class="div-fixed">
            <div id="btn-cadastrar-submit">
                <a href="@Url.Action("Index")" type="button" class="btn-rounded bg-transparent border-white text-white text-center">
                    <span class="fa fa-remove"></span> Cancelar
                </a>
                <button type="submit" class="btn-rounded bg-green">
                    <span class="fa fa-save"></span> Salvar
                </button>
            </div>
        </div>
    }
</div>


@section Scripts
{

    <script>
        function exibirAlteradorFoto() {
            $('#div-foto-atual').hide();
            $('#div-alteracao-foto').show();

            // $('#div-alteracao-foto').removeClass('d-none'); 
        }

        function exibeImagemAtual(){
            $('#imagemRecortada').val('');

            $('#div-foto-atual').show();
            $('#div-alteracao-foto').hide();
        }


    </script>
    <script src="~/js/3th/summernote/summernote-bs4.js"></script>
    <script src="~/js/3th/summernote/summernote-pt-BR.js"></script>
    <script src="~/js/3th/croppie/croppie.min.js"></script>
    <script src="~/js/3th/croppie/exif.min.js"></script>
    <script src="~/js/noticia/cropNoticia.js"></script>
    <script>
        $(document).ready(function () {
            $('#div-alteracao-foto').hide();

            $('#Descricao').summernote({
                fontStyle: {
                    foreColor: 'black'
                },
                height: 500,
                lang: 'pt-BR',
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['font', ['strikethrough', 'superscript', 'subscript']],
                    ['fontsize', ['fontsize']],
                    ['color', ['color']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['height', ['height']]
                ]
            });
            $('#Descricao').summernote('foreColor', 'black');
            loadImagemInCrop();
        });
    </script>
}