{
  "metadata": [
    {
      "src": [
        {
          // Aponta para o diretï¿½rio do projeto onde os arquivos .csproj estï¿½o localizados.
          // Se o .csproj estiver na raiz, vocï¿½ pode usar "." para indicar o diretï¿½rio atual.
          "files": [ "**/*.csproj" ],
          "exclude": [ "**/obj/**", "**/bin/**", "**/node_modules/**" ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        // Inclui os arquivos YAML gerados e qualquer arquivo markdown ou TOC na documentaï¿½ï¿½o.
        "files": [ "api/**.yml", "toc.yml", "*.md" ]
      }
    ],
    "resource": [
      {
        // Inclui recursos como imagens dentro da pasta 'wwwroot', se necessï¿½rio.
        "files": [ "wwwroot/images/**" ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_enableSearch": true
    },
    "template": [ "default", "statictoc" ],
    "overwrite": [ "apidoc/**.md" ]
  }
}
