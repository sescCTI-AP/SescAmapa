@model SiteSesc.Models.ViewModel.UsuarioResetSenha
@{
    Layout = "_Empty";
}
<style>
    .child {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }
</style>
<div class="container">
    <div class="child">
        <img src="~/images/static/HomeIndex/logo/logo.png" alt="" width="150" class="pb-5">
        <h3>Informe uma nova senha</h3>
        <p class="text-danger">@ViewBag.Validation</p>
        <form asp-action="ConfirmaSenha" asp-controller="Usuario" method="post">
            <input asp-for="Guid" hidden value="@ViewBag.Guid" />
            <div class="form-group">
                <label for="senha">Senha:</label>
                <input asp-for="Senha" class="form-control" />
                <span asp-validation-for="Senha" class="text-danger"></span>

            </div>

            <div class="form-group">
                <label for="confirmaSenha">Confirme sua senha:</label>
                <input asp-for="ConfirmarSenha" class="form-control" />
                <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
            </div>

            <input type="submit" value="CONFIRMAR" class="theme-btn theme-btn-big mt-5">
        </form>
    </div>
</div>