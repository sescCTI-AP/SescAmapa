@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model SiteSesc.Models.ViewModel.UsuarioViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Login.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<style>

    /* Define the font size and spacing for the "Novo cadastro" link */
    .novo-cadastro {
        font-size: 14px; /* Adjust the size as needed */
        margin-right: 20px; /* Add spacing between the links */
    }
    /* Define the font size and spacing for the "Esqueci minha senha" link */
    .esqueci-senha {
        font-size: 10px; /* Adjust the size as needed */
        margin-left: 220px; /* Add spacing between the links */
    }

    .alert-warning{
        display: flex;
        flex-direction: row;
    }

    .msgEmailE {
        width: 100%;
        max-width: 50px;
        margin-right: 1rem;
        color:rgb(246,190,0);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        animation: starR 3s ease-in-out infinite;
    }

    @@keyframes starR {
        0%      {transform: translatey(5px)}
        50%     {transform: translatey(-5px)}
        100%    {transform: translatey(5px)}
    }
    
    .msgEmailD{
        text-align: left;
    }

    .pb-3{
        padding: 0 !important;
    }

    .half{
        position: relative;
    }

    .col-md-7{
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: white;
    }

    .logo{
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        max-width: 400px;
        max-height: 100px;
        margin-top: 5px;
        padding: 3rem 1.5rem;
        border-radius: 1rem;
        margin-bottom: 2vh;
        cursor: pointer;
    }

    .logo img{
        width: 100%;
        min-width: 150px;
    }

    #bg-carroussel {
        margin:0; 
        width: 100%;
        height: 100%;
        overflow: auto;
        background-image: url("images/static/bg_pessoas.webp");
        background-size:cover;
    }


    .password-container {
        position: relative;
        width: 100%;
    }

    #password {
        width: 100%;
        padding: 10px;
        padding-right: 40px;
        box-sizing: border-box;
    }

    #togglePassword {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        outline: none;
    }

    #eyeIcon {
        font-size: 20px;
    }

    .botoes { 
        background: white; 
        text-align: center;
        border-radius: 1rem;
        padding: 0.5rem;
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .botoes div{
        font-size: 1.2rem;
        margin: 0.5rem;
        text-align: center;
    }

    .forgot-pass{
        cursor: pointer;
    }

    @@media only screen and (min-width: 577px) {
        
        #bg-carroussel {
            display: flex !important;
        }

        .caixaLogin{
            position: absolute;
            width: 100% !important;
            overflow: auto !important;
        }

        #bg-carroussel {
            position: absolute;
            width: 100%;
            height: 100%;
        }

        .col-md-7{
            background: rgba(255, 255, 255, 0.8);
            border-radius: 1rem;
            padding: 2rem;
            backdrop-filter: blur(6px);
            width: auto !important;
        }

        .form-group {background: white;}
        
        .botoes { 
            border-radius: 1rem;
            padding: 0.5rem 0;
         }

    }

    @@media only screen and (max-width:576px) {
        .alert-warning{
            flex-direction: column;
        }

        .msgEmailE{ 
            margin: auto; 
            margin-bottom: 1rem;
        }

        .msgEmailD{
            text-align: center;
        }

        .col-md-7{
            scale:90%
        }

        .col-md-7{
            padding: 0 2rem;
        }
        
        .logo{
            max-width:430px !important;
            max-height: 150px;
            scale:100%;
            height: auto;
            background: white;
            padding: 1.0rem 1.25rem clamp(1rem, 1rem + 5vh, 3rem);;
            margin: 0;
        }

        #bg-carroussel {
            display: none !important;
        }

        .caixaLogin{
            width: 100% !important;
            background: white;
        }
        
        .botoes div{
            font-size: 1.2rem;
            margin: 0.5rem;
            text-align: center;
        }
       
    }

</style>


<div class="d-lg-flex half">
    <div class="contents order-2 order-md-1 caixaLogin">
        <div class="container">
            <div class="row align-items-center justify-content-center">
                <div class="col-md-7">
                    @if (ViewBag.EnviaEmail ?? false)
                    {
                        <div class="alert alert-warning">
                            <div class="msgEmailE">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                    <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                </svg>
                            </div>
                            <div class="msgEmailD">
                                É necessário ativar seu perfil através do e-mail de confirmação de usuário que foi enviado para você.
                            </div>
                        </div>
                    }
                    <div class="logo">
                        <a href="@Url.Action("Index", "Home")">
                            <img src="~/images/static/LogoConjuntaHorizontal.webp">
                        </a>
                    </div>

                    <h3>Faça seu login:</h3>
                    @* <h3>Login <strong>Sesc @Configuration["Ambiente:UF"]</strong></h3> *@
                    <span class="text-danger">@ViewBag.Validacao</span>
                    <form asp-action="Login" asp-controller="Usuario" method="post" style="text-align: center;">
                        @if (ViewBag.UrlRedirect != null)
                        {
                            <input value="@ViewBag.UrlRedirect" name="cdelement" hidden />
                        }
                        <div class="form-group first">
                            <label for="cpf">CPF</label>
                            <input asp-for="Username" name="Username" type="text" class="form-control" placeholder="Digite seu usuário ou CPF">
                        </div>
                        <div class="form-group last mb-3">
                            <label for="senha">Senha</label>
                            <div class="password-container">
                                <input asp-for="Senha" name="Senha" type="password" class="form-control" placeholder="Digite sua senha" id="senha" name="senha">
                                <button type="button" id="togglePassword">
                                    <i id="eyeIcon" class="fa fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="botoes">
                            <div>
                                <span class="ml-auto"><a asp-action="Create" asp-controller="Usuario" class="forgot-pass">Cadastre-se</a><br/></span>
                            </div>
                            <div>
                                <span class="ml-auto">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
                            </div>
                            <div>
                                <span class="ml-auto"><a data-bs-toggle="modal" data-bs-target="#modal-recupera-senha" class="forgot-pass">Esqueci minha senha</a></span>
                            </div>
                        </div>

                        <input type="submit" value="Acessar" class="theme-btn theme-btn-big">
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>


<div class="modal fade" id="modal-recupera-senha" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Recuperar senha</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="div-form-recupera">
                    <div class="form-group">
                        <label>Informe o CPF do usuário</label>
                        <input class="form-control" name="cpf" id="cpf" />
                    </div>
                </div>
                <div id="div-success">
                    <p id="msg-success" class="text-black"></p>
                </div>
            </div>
            <div class="modal-footer">
                <a id="btn-enviar" onclick="recuperarSenha()" class="btn btn-primary">Enviar</a>
                <button id="btn-cancel" type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script>
        /*
        const carroussel = document.getElementById('bg-carroussel');
        const imagens = carroussel.getElementsByClassName('bgimage');
        let index = 0;

        function trocarImagem() {
            imagens[index].classList.remove('active');
            index = (index + 1) % imagens.length;
            imagens[index].classList.add('active');
        }

        setInterval(trocarImagem, 3000);
        */

        function recuperarSenha() {
            var cpf = $('#cpf').val();
            console.log("tamanho: " + cpf.length);
            if (cpf != "") {
                fetch('/recuperar-senha/' + cpf)
                    .then(response => response.text())
                    .then(data => {
                        if(data != ''){
                            console.log("response: " + data);
                            $('#btn-enviar').hide();
                            $('#btn-cancel').text("Fechar");
                            $('#div-form-recupera').hide();
                            $('#msg-success').text("Foi enviado um email para " + data + ". Clique no link enviado para resetar a senha.");
                        }else{
                            $('#msg-success').text("Usuário não encontrado");
                        }

                    })
                    .catch(error => console.error('Erro:', error));
            }
        }

        document.getElementById('togglePassword').addEventListener('click', function (e) {
            const passwordField = document.getElementById('senha');
            const eyeIcon = document.getElementById('eyeIcon');
            const isPasswordVisible = passwordField.type === 'password';

            console.log(isPasswordVisible);

            if (isPasswordVisible) {
                passwordField.type = 'text';
                eyeIcon.classList.remove('fa-eye');
                eyeIcon.classList.add('fa-eye-slash');
            } else {
                passwordField.type = 'password';
                eyeIcon.classList.remove('fa-eye-slash');
                eyeIcon.classList.add('fa-eye');
            }
        });
    </script>
}