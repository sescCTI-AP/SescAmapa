                                        foreach (var item in itens.Where(c => c.ItemCardapio.IdGrupoItemCardapio == 5).ToList())
                                        {
                                            <li>
                                                @item.ItemCardapio.Nome
                                            </li>
                                        }
                                    }
                                </ul> *@
                            }
                        </div>
                    </div>
                }

