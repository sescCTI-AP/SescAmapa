            }

            <script>
                function unidadeSelecionada(v){
                    let uni = '#unidade-'+v;
                    $(".crdpContainer").not(uni).hide('fast');
                    $('#unidade-'+v).toggle('fast');
                    $('#unidadeItem-'+v).toggleClass('cardapioUnidadeAtiva');
                    $('.nav-link').not('#unidadeItem-'+v).removeClass('cardapioUnidadeAtiva');
                }
            </script>
        
        </div>
        <div class="text-center">
            <span style="font-size: 12px; color: red">*Cliente informamos que o cardápio pode, eventualmente, sofrer alterações de acordo com a disponibilidade dos itens e/ou fatores externos.</span>
