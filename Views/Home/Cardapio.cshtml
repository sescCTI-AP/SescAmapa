@model List<SiteSesc.Models.Cardapio.cdp_ComposicaoCardapio>
@using System.Globalization
@using SiteSesc.Models.Cardapio
@{
    var dia = DateTime.Today.ToString("dddd", new CultureInfo("pt-BR"));
    var hora = DateTime.Now.Hour;
    if (dia.ToLower() == "segunda-feira" && hora > 14)
    {
        dia = "terça-feira";
    }
    else if (dia.ToLower() == "terça-feira" && hora > 14)
    {
        dia = "quarta-feira";
    }
    else if (dia.ToLower() == "quarta-feira" && hora > 14)
    {
        dia = "quinta-feira";
    }
    else if (dia.ToLower() == "quinta-feira" && hora > 14)
    {
        dia = "sexta-feira";
    }

    var idPalmas = 1;
    var idGurupi = 9;
    var unidades = ViewBag.Unidades as List<UnidadeOperacional>;
    var grupos = ViewBag.GrupoItens as List<cdp_GrupoItemCardapio>;
}

<style>

    .nav-link{cursor: pointer;}
    .cardapioContainer{width: calc(100% - 2rem);; max-width: 1200px; margin: 2rem auto;}
    .areaTitulo{
        background: url("../images/cardapio.webp") center no-repeat;
        background-size: cover;
        color: white;
        min-height: 200px;
        width: calc(100% - 2rem);
        max-width: 1600px;
        overflow: hidden;
        padding: 0 1rem;
        margin: 1rem auto;
        border-radius: 0.5rem ;
        display: flex;
        justify-content: flex-start;
        align-items: center;
    }

    .areaTitulo h2{
        color: white;
        text-shadow: 0 0 50px black;
        font-size: clamp(30px, 30px + 1vw, 46px)
    }

</style>


@*-----------CONTEUDO-----------*@
<div class="areaTitulo">
    <h2>
        Cardápio
    </h2>
</div>
<div class="cardapioContainer">


    <div class="pt-0">
        <div class="pr-0">
            
            <div class="text-center">
                @*-----------IMAGEM DIA E TITULO-----------*@

                <div class="alert alert-danger text-center" style="display: block;">
                    <p style="font-size: 18px; "><strong>COMUNICADO RESTURANTE DO COMERCIÁRIO – BELÉM (RUA SEN. MANOEL BARATA)</strong></p>
                    <p style="font-size: 14px; text-align:justify;">Informamos que, em virtude do furto de cabos da rede elétrica, até 01/11 (sexta-feira), as refeições serão servidas em marmitas, entregues na unidade Sesc Ver-o-peso (Blvd. Castilhos França, 522/523 – Campina), no horário das 11h00 às 14h00. Logo que a energia neste prédio for reestabelecida, voltaremos às atividades normais.</p>
                    <p>A Direção Regional do Sesc no Pará.</p>
                </div>



                <div class="row">
                    <div class="col">
                        <div class="text-center">
                            <label style="text-transform: uppercase; margin-right: 20px">
                                @if (dia.ToLower() == "sábado" || dia.ToLower() == "domingo")
                                {
                                    <h5 style="text-transform:capitalize">SEGUNDA-FEIRA</h5>
                                }
                                else
                                {
                                    <h5 style="text-transform:capitalize">@dia</h5>
                                }
                            </label>
                        </div>
                    </div>
                </div>
                <p>Selecione uma unidade abaixo</p>
                @if (unidades != null)
                {
                    <ul class="nav nav-pills">
                        @foreach (var unidade in unidades)
                        {
                            string nomeDeclarado = "";
                            @if(unidade.Nome == "CENTRO DE ATIVIDADES DO SESC BELÉM - SESC DOCA  "){
                                nomeDeclarado = "Sesc Doca";
                            }else if(unidade.Nome == "RESTAURANTE DO COMERCIARIO CENTRAL"){
                                nomeDeclarado = "Restaurante do Comerciário";
                            }else{
                                nomeDeclarado = unidade.Nome;
                            }

                            <li class="nav-item p-1">
                                <a class="nav-link cardapioUnidadeDefault" onclick="unidadeSelecionada(@unidade.Id)" id="unidadeItem-@unidade.Id" >@nomeDeclarado</a>
                            </li>
                        }
                    </ul>
                }
            </div>


