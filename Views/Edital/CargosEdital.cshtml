                document.getElementById("drop-area-rgcnh").style.display = "block";
                document.getElementById("drop-area-cpf").style.display = "block";
                document.getElementById("drop-area-pis").style.display = "block";
                document.getElementById("drop-area-comprovante_bancario").style.display = "block";
                document.getElementById("drop-area-certificado_escolar").style.display = "block";
                document.getElementById("drop-area-comprovante_residencia").style.display = "block";

            } else if (tipoPessoa === "2") { // Pessoa Jurídica
                document.getElementById("drop-area-cnpj").style.display = "block";
                document.getElementById("drop-area-fgts").style.display = "block";
                document.getElementById("drop-area-cs_eirelli").style.display = "block";
                document.getElementById("drop-area-estatuto").style.display = "block";
                document.getElementById("drop-area-requerimento_ei").style.display = "block";
