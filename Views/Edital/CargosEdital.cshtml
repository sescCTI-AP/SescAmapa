@model IEnumerable<SiteSesc.Models.Edital.edt_cargoEdital>
@using SiteSesc.Models.Edital
@using SiteSesc.Repositories
@using SiteSesc.Models.Edital.ViewModel
@{
    ViewBag.Title = "Cargos";
    var cargos = ViewBag.Cargos as List<CargoViewModel>;
    var listaPessoa = ViewBag.tipoPessoaEdital as List<edt_tipoPessoaEdital>;
    var processo = ViewBag.Edital as edt_edital;
    var edital = Model.First();
    bool hasExperiencia = false;
    bool hasFormacao = false;
}

<style>
    #formCurriculo label {
        margin-top: 20px;
        margin-bottom: 0px
    }

    .border-dashed {
        border: 1px solid white;
        margin-top: 10px;
        margin-bottom: 10px;
        border-radius: 30px;
        padding: 10px
    }

    .alert {
        border-radius: 20px !important
    }

    .iconValid {
        color: green;
    }

    label {
        margin-top: 2px !important
    }

    .drop-area {
        border: 2px dashed #ccc;
        border-radius: 20px;
        width: 400px;
        font-family: sans-serif;
        margin: 20px auto;
        padding: 20px;
    }

        .drop-area:hover {
            border-color: #333;
        }

    .fileElem {
        display: none;
    }
</style>

<div class="container bg-white" style="margin-top: 50px; margin-bottom: 100px">

    <h4>Edital Nº. @processo.NumeroEdital</h4>

    <h6 class="mt-5">Cargos disponíveis</h6>

    <table class="table table-hover" id="table-cargos">
        <tr>
            <th>
                CARGO
            </th>
            <th>
                PROJETO
            </th>
            <th>
                VALOR
            </th>
            <th>
                CIDADE
            </th>
            <th class="text-center">
                LIMITE DE CURRÍCULOS
            </th>
            <th class="text-center">
                CURRÍCULOS RECEBIDOS
            </th>
            <th></th>
            <td></td>
        </tr>
        @foreach (var item in cargos)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Cargo.Nome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Cargo.Projeto)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Cargo.Valor)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Cargo.Cidade.Nome)
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.Cargo.VagasCurriculo)
            </td>
                <td class="text-center">
                    <span>@item.CurriculosRecebidos</span>
            </td>
                <td>
                    @if (item.VagasDisponiveis > 0 && processo.DataFimCurriculo.HasValue && processo.DataFimCurriculo.Value > DateTime.Now)
                    {
                        <a class="text-white theme-btn" onclick="showModal('@item.Cargo.Id','@item.Cargo.HasDocExperiencia', '@item.Cargo.HasDocFormacao');">Inscreva-se</a>
                    }
                    else
                    {
                        
                    }
                </td>
                <td>
                    <a class="btn btn-warning theme-btn" href="@Url.Action("Acompanhar","Edital", new { Id = item.Cargo.Id })">Acompanhar</a>
                </td>
            </tr>
        }
    </table>
</div>

