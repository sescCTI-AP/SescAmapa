                document.getElementById("drop-area-certidao_negativa_municipal_estadual").style.display = "block";
                document.getElementById("drop-area-estatuto_social").style.display = "block";
                document.getElementById("drop-area-regularidade_fgts").style.display = "block";

            }
            else if (tipoPessoa === "3") { // Pessoa Jurídica MEI
                document.getElementById("drop-area-mei").style.display = "block";
                document.getElementById("drop-area-ccmei").style.display = "block";
                document.getElementById("drop-area-cnpj_mei").style.display = "block";
                document.getElementById("drop-area-fgts_mei").style.display = "block";
                document.getElementById("drop-area-certidao_negativa_federal_mei").style.display = "block";
                document.getElementById("drop-area-certidao_negativa_municipal_estadual_mei").style.display = "block";
            }
            else if (tipoPessoa === "4") { // Associações
                document.getElementById("drop-area-cnpj_acessoria").style.display = "block";
                document.getElementById("drop-area-fgts_acessoria").style.display = "block";
                document.getElementById("drop-area-cs_eirelli_associacao").style.display = "block";
                document.getElementById("drop-area-estatuto_associacao").style.display = "block";
                document.getElementById("drop-area-requerimento_ei_associacao").style.display = "block";
                document.getElementById("drop-area-certidao_negativa_federal_associacao").style.display = "block";
                document.getElementById("drop-area-certidao_negativa_municipal_estadual_associacao").style.display = "block";
                document.getElementById("drop-area-estatuto_social_associacao").style.display = "block";
                document.getElementById("drop-area-estatuto_associacao_representante").style.display = "block";
            }

            $.LoadingOverlay("hide");

        }

