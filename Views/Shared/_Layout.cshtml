@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Web
@using SiteSesc.Repositories;

<!DOCTYPE html>
<html lang="pt-br">


 @{
    var request = this.ViewContext.HttpContext.Request;
    var urlAtual = $"{request.Scheme}://{request.Host}{request.Path}{request.QueryString}";
    var caminhoImagem = "";
    string caminhoDescricao ="";
    
    
    string[] words = urlAtual.Split('/');
    int cont = @words.Length - 1;    
    //Verifica se a página aberta é uma notícia
    if(this.ViewBag.NoticiaTituloUrl != null){
       words[cont] = this.ViewBag.NoticiaTituloUrl;        
       caminhoImagem = this.ViewBag.caminhoVirtual;
        int size = this.ViewBag.caminhoVirtual.Length;
        caminhoDescricao = this.ViewBag.caminhoVirtual.Replace("&nbsp;", " ");
        caminhoDescricao = caminhoDescricao.Substring(0, (caminhoDescricao.Length < 150 ? caminhoDescricao.Length : 150));
    }else
    if(this.ViewBag.AtvTituloUrl != null){
       words[cont] = this.ViewBag.AtvTituloUrl;        
       caminhoImagem = this.ViewBag.AtvCaminhoVirtual;
       int size = this.ViewBag.AtvTextoUrl.Length;
       caminhoDescricao = this.ViewBag.AtvTextoUrl.Replace("&nbsp;", " ");
       caminhoDescricao = caminhoDescricao.Substring(0, (caminhoDescricao.Length < 150 ? caminhoDescricao.Length : 150));

    }
    else if(this.ViewBag.nomeLicitacao != null){
       words[cont] = "Licitação Nº " + this.ViewBag.nomeLicitacao ;               
    }
    else if(this.ViewBag.nomeProcessoSeletivo != null){
        words[cont] = "Processo Seletivo Nº " + this.ViewBag.nomeProcessoSeletivo ;  
    }
    else if(this.ViewBag.nomeEdital != null){
        words[cont] = "Edital de Credenciamento Nº " + this.ViewBag.nomeEdital ;  
    }
    else if (this.ViewBag.ProgTitulo != null)
    {
        words[cont] = this.ViewBag.ProgTitulo;
    }
} 


<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#004c99">
    <meta http-equiv="content-type" content="text/html; charset=UTF-8" />
    

    <!-- Favicons -->
    <link href="~/images/static/logo-mini.png" rel="icon">
    <link href="~/images/static/logo-mini.png" rel="apple-touch-icon">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SiteSesc.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Public/animate.min.css">
    <link rel="stylesheet" href="~/css/Public/magnific-popup.css">
    <link rel="stylesheet" href="~/css/Public/odometer.min.css">
    <link rel="stylesheet" href="~/css/Public/nice-select.css">
    <link rel="stylesheet" href="~/css/Public/meanmenu.css">
    <link rel="stylesheet" href="~/css/Public/swiper-bundle.min.css">
    <link rel="stylesheet" href="~/css/Public/mainpublic.css">
    <script src="~/js/FontAwesome6.js"></script>

    <!--google fonts-->
    <link href='https://fonts.googleapis.com/css?family=Montserrat:400,700' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Raleway' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Montez' rel='stylesheet' type='text/css'>


</head>

<script src="~/lib/jquery/dist/jquery.min.js"></script>

<body id="start_nicdark_framework">

    <div class="sidebar-info side-info">
        <div class="sidebar-logo-wrapper mb-25">
            <div class="row align-items-center area-logo-top">

                    <div class="sidebar-area-logo">
                        <a href="@Url.ActionLink("Index","Home")">
                            <img src="~/images/static/HomeIndex/logo/logo-white.webp" alt="logo-img">
                        </a>
                    </div>


                    <div class="sidebar-area-close">
                        <button class="sidebar-close side-info-close botao-fechar">
                            <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/>
                            </svg>
                        </button>
                    </div>

            </div>
        </div>
        <div class="sidebar-menu-wrapper fix">
            <div class="mobile-menu"></div>
        </div>
    </div>

    <div class="offcanvas-overlay"></div>

    <!-- header area start -->
    <header>
        <div class="header-area header-sticky">
            <div class="container">
                <div class="row align-items-center altura-Testeira">

                    <div class="header-left">
                        <div class="header-logo">
                            <a href="@Url.ActionLink("Index","Home")">
                                <img src="~/images/static/HomeIndex/logo/logo.webp" class="img-index" alt="logo do Sesc no Pará" width="150">
                            </a>
                        </div>

                    </div>
                    
                    <div class="header-center">
                            <nav class="main-menu mobile-menu d-none d-xl-block" id="mobile-menu">
                                <ul class="topo">
                                    
                                    <li class="menu-has-child">
                                        <a asp-controller="Home" asp-action="Index">Início 
                                            @* @words[( words.Length - 1)].Length *@
                                        </a>
                                    </li>
                                    
                                    <li class="menu-has-child">
                                        <a href="#" id="sub-instucional">Institucional</a>
                                        <ul class="submenu submenu1">
                                         
                                            <li><a asp-action="Index" asp-controller="Sobre">Sobre</a></li>
                                        </ul>
                                    </li>
                                    

                                </ul>
                            </nav>
                    </div>
                    
                    
                    <div class="header-right">
                                <a href="@Url.Action("Login","Usuario")" class="header-btn theme-btn theme-btn-medium">Espaço do Cliente</a>
                        <div class="header-menu-bar d-xl-none ml-10">
                            <span class="header-menu-bar-icon side-toggle">
                                <i class="fa-solid fa-bars"></i>
                            </span>
                        </div>
                    </div>
                    

                </div>
            </div>
        </div>
    </header>
    <!-- header area end fim -->
    
    <main>

        @RenderBody()

        <div class="modal fade" id="modal-cardapio" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">Cardápio</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .cta-area{
                padding-top: 2.5rem;
            }

            .footer-widget-list ul li a:focus {color: var(--clr-theme-primary);}
        </style>
        
    </main>

    <!-- footer area start -->
    <footer class="footer-area">
        <div class="footer-top pt-240 pb-55">
            <div class="container">
                <div class="row justify-content-between">
                    <div class="col-xl-3 col-lg-5 col-md-5 col-sm-12">
                        <div class="footer-widget mb-40">
                            <div class="footer-logo">
                                <a href="@Url.ActionLink("Index","Home")"><img src="~/images/static/HomeIndex/logo/footer.webp" alt="Logo do sisitema Fecomércio-PA | Sesc | Senac"></a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </footer>
    <!-- footer area end -->

    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/swiper-bundle.min.js"></script>
    <script src="~/js/jquery.meanmenu.min.js"></script>
    <script src="~/js/wow.min.js"></script>
    <script src="~/js/jquery.nice-select.min.js"></script>
    <script src="~/js/jquery.scrollUp.min.js"></script>
    <script src="~/js/jquery.magnific-popup.min.js"></script>
    <script src="~/js/odometer.min.js"></script>
    <script src="~/js/appear.min.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/css/swiper/swiper-bundle.min.js"></script>
    <script src="~/css/swiper/initializeswiper.js"></script>
    <script src="~/js/3th/loadingoverlay.min.js"></script>
    <script src="~/js/3th/jquery.noty.packaged.min.js"></script>
    
   
    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>