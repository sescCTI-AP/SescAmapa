</section>

<script>
    function share(){
        if (navigator.share !== undefined) {
            navigator.share({
                title: 'Sesc no Pará',
                text: "@WebUtility.HtmlDecode(Model.TituloCurto)",
                url: "@textoConcat",
            })
            .then()
            .catch((error) => console.log('Error sharing', error));
        }
    }
</script>
