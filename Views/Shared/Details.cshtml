                </div>
            </div>
            <div class="col-xl-4 col-lg-4">
                <div class="blog_details-sidebar mb-60">
                    <div class="blog_details-widget">
                        <h4 class="blog_details-widget-title">Busca</h4>
                        <form action="#">
                            <input type="text" placeholder="Procure algo">
                            <button type="submit"><i class="fa-solid fa-search"></i></button>
                        </form>
                    </div>
                    <div class="blog_details-widget">
                        <h4 class="blog_details-widget-title">Posts recentes</h4>

                        @if (listPostsRecentes != null)
                        {
                            foreach (var post in listPostsRecentes)
                            {
                                @await Html.PartialAsync("PartialView/_PartialViewPostsRecentes", post)

                            }
                        }

                    </div>
                    <div class="blog_details-widget widget-category">
                        <h4 class="blog_details-widget-title">Categorias</h4>
                        <div class="blog_details-widget-category">
                            <ul>
                                @if (listAreas != null)
                                {
                                    foreach (var area in listAreas)
                                    {
                                        <li><a href="@Url.Action("Index", "Area", new { nome = area.NameRoute})">@area.Nome</a></li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
