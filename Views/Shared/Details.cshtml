@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model SiteSesc.Models.Noticia
@using SiteSesc.Models.ModelPartialView
@using System.Text
@using System;
@using System.Net;

@{
    var listaNoticias = ViewBag.ListNoticias as List<NoticiaCard>;
    var listComentarios = ViewBag.ListComentarios as List<Comentarios>;
    var listPostsRecentes = ViewBag.ListPostsRecentes as List<PostsRecentes>;
    var listAreas = ViewBag.ListAreas as List<Area>;
}

<section class="blog_details-area pt-120 pb-80">
    <div class="container">
        <div class="blog_details-img">
            <img src="@Model.Arquivo.CaminhoVirtualFormatado()" width="100%" alt="@Model.TituloCurto" loading="lazy" >
        </div>
        <div class="row">
            <div class="col-xl-8 col-lg-8">
                <div class="blog_details-wrap mb-60">
                    <div class="blog_details-top mb-50">
                        <h3 class="blog_details-title">@Model.TituloCurto</h3>
                        
                        <div class="blog_details-meta">
                            <div class="blog_details-author">
                                @*                                 <div class="blog_details-author-img">
                                <img src="~/images/erika.jpg" style="border-radius: 50%" alt="">
                                </div> *@
                                <div class="blog_details-author-info">
                                    <span>Autor</span>
                                    <h5><a @*href="team.html"*@>@Model.Usuario.Nome</a></h5>
                                </div>
                            </div>
                            <div class="blog_details-category">
                                <h5><a href="#">@Model.Area.Nome</a></h5>
                                <h5 class="blog_details-title">@Model.IdUnidade.NomeCurto</h5>
                            </div>
                            <div class="footer-social">
                                <span>Compartilhe essa notícia</span>
                                            @{
                                                string textoConcat = "https://sesc-pa.com.br"; 
                                                string[] words = ViewBag.CurrentUrl.Split('/');
                                                for (int i = 3; i < words.Length; i++)
                                                {
                                                    textoConcat = textoConcat +"/"+ Encoding.UTF8.GetString(Encoding.Default.GetBytes(@words[i]));
                                                }
                                            }
                                            <ul>
                                                <!--<li><a href="#"><i class="fa-brands fa-x-twitter"></i></a></li>-->
                                                <li class="padronizar-share-icon">
                                                    <a target="_blank" href="https://www.facebook.com/sharer/sharer.php?u=@textoConcat">
                                                    <i class="fa-brands fa-facebook-f"></i>
                                                    </a>
                                                </li>
                                                <li class="padronizar-share-icon">
                                                    <a target="_blank" href="https://www.linkedin.com/shareArticle?mini=true&url=@textoConcat">
                                                        <i class="fa-brands fa-linkedin-in"></i>
                                                    </a>
                                                </li>
                                                <li class="padronizar-share-icon">
                                                    <a target="_blank" href="https://api.whatsapp.com/send?text=@textoConcat" >
                                                        <i class="fa-brands fa-whatsapp"></i>
                                                    </a>
                                                </li>
                                                <li class="padronizar-share-icon">
                                                    <a onclick="share()">
                                                        <i class="fa fa-share" aria-hidden="true"></i>
                                                    </a>
                                                </li>
                                            </ul>
                            </div>
                        </div>
                    </div>
                    <div class="blog_details-content">
                        <div class="blog_details-inner-text mr-80">
                            @*Remover para o conteúdo *@
                            <p>@Html.Raw(Model.CorpoNoticia)</p>
                        </div>

                        <div class="blog_details-highlight">
                            <div class="blog_details-highlight-img">
                                <img src="assets/img/blog/details/2.jpg" alt="">
                            </div>
                            <div class="blog_details-highlight-text">
                                <h3>Saiba tudo o que o Sesc @Configuration["Ambiente:Estado"] oferece.</h3>
                            </div>
                        </div>
                    </div>

                    @*                     <div class="event-active swiper pb-80">
