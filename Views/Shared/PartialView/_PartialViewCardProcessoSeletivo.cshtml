@model SiteSesc.Models.ProcessoSeletivo.psl_processoSeletivo

<style>
    .status-aberto {
        color: green;
    }

    .status-andamento {
        color: #F4A460;
    }

    .status-finalizado {
        color: red;
    }
</style>

<div class="flex-item">
    <a asp-action="Details" asp-controller="ProcessoSeletivo" asp-route-num="@Model.NumeroProcessoSeletivo.Replace("/", "-")">
        <div class="blog_details-widget mb-0">
            <div class="box-titulo-blue">
                <h4>Processo Seletivo Nº @Model.NumeroProcessoSeletivo</h4>
            </div>
            <div class="box-conteudo-ps">

                <p class="mb-0 box-texto-cargos">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-person-check" viewBox="0 0 16 16">
                        <path d="M12.5 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7m1.679-4.493-1.335 2.226a.75.75 0 0 1-1.174.144l-.774-.773a.5.5 0 0 1 .708-.708l.547.548 1.17-1.951a.5.5 0 1 1 .858.514M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0M8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4"/>
                        <path d="M8.256 14a4.5 4.5 0 0 1-.229-1.004H3c.001-.246.154-.986.832-1.664C4.484 10.68 5.711 10 8 10q.39 0 .74.025c.226-.341.496-.65.804-.918Q8.844 9.002 8 9c-5 0-6 3-6 4s1 1 1 1z"/>
                    </svg>
                    Cargos: @if (Model.psl_cargoProcessoSeletivo != null)
                    {
                        foreach (var (cargo, index) in Model.psl_cargoProcessoSeletivo.Select((valor, indice) => (valor, indice)))
                        {
                            <span>@cargo.Nome</span>
                            if (index < Model.psl_cargoProcessoSeletivo.Count() - 1)
                            {
                                <span>,</span>
                            }
                        }
                    }
                </p>
                <p class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-chat-square-text" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-2.5a2 2 0 0 0-1.6.8L8 14.333 6.1 11.8a2 2 0 0 0-1.6-.8H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2.5a1 1 0 0 1 .8.4l1.9 2.533a1 1 0 0 0 1.6 0l1.9-2.533a1 1 0 0 1 .8-.4H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                        <path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 6a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 6m0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
                    </svg>
                    Áreas: @if (Model.psl_areasProcessoSeletivo != null)
                    {
                        foreach (var (area, index) in Model.psl_areasProcessoSeletivo.Select((valor, indice) => (valor, indice)))
                        {
                            <span>@area.Area.Nome</span>
                            if (index < Model.psl_areasProcessoSeletivo.Count() - 1)
                            {
                                <span>,</span>
                            }
                        }
                    }
                </p>
                <p class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-geo-alt" viewBox="0 0 16 16">
                    <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A32 32 0 0 1 8 14.58a32 32 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10"/>
                    <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4m0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                    </svg>
                    Cidades: @if (Model.psl_cidadesProcessoSeletivo != null)
                    {
                        foreach (var (cidade, index) in Model.psl_cidadesProcessoSeletivo.Select((valor, indice) => (valor, indice)))
                        {
                            <span>@cidade.Cidade.Nome</span>
                            if (index < Model.psl_cidadesProcessoSeletivo.Count() - 1)
                            {
                                <span>,</span>
                            }
                        }
                    }
                </p>
                <p class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="18" fill="currentColor" class="bi bi-calendar-week" viewBox="0 0 16 16">
                    <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm-3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm-5 3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z"/>
                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                    </svg>
                    Data de abertura: @Model.DataPublicacao.ToShortDateString()
                </p>
                <p class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-square" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                        <path d="M10.97 4.97a.75.75 0 0 1 1.071 1.05l-3.992 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z" />
                    </svg>
                    Situação:
                    <b class="@(Model.psl_statusProcessoSeletivo.Descricao == "Aberto" ? "status-aberto" :
                Model.psl_statusProcessoSeletivo.Descricao == "Em Andamento" ? "status-andamento" :
                "status-finalizado")">
                        @Model.psl_statusProcessoSeletivo.Descricao
                    </b>
                </p>
                
            </div>
        </div>
    </a>
</div>