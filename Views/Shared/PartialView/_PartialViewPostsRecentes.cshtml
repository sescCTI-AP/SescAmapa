@model SiteSesc.Models.ModelPartialView.PostsRecentes

<div class="blog_details-widget-post">
    <div class="blog_details-post-img">
        <a href="@Url.Action("Details", "Noticia", new { area = Model.nameRoute, slug = Model.slug })"><img src="@Model.PostImage" style="width:100px; height: 100px;object-fit:cover" alt=""></a>
    </div>
    <div class="blog_details-post-info">
        <span><i class="fa-regular fa-clock"></i>@Model.PostDate.ToString("MMMM dd, yyyy")</span>
        <h6><a href="@Url.Action("Details", "Noticia",  new { area = Model.nameRoute, slug = Model.slug })">@Model.PostTitle</a></h6>
    </div>
</div>