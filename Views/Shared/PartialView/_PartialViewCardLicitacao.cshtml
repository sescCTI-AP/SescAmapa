@model SiteSesc.Models.Licitacao.lct_licitacao

<style>
    .status-aberto {
        color: green ;
    }

    .status-aaberto {
        color: silver;
    }

    .status-andamento {
        color: #F4A460;
    }

    .status-finalizado {
        color: red;
    }
</style>

<div class="flex-item">
    <a asp-action="Details" asp-controller="Licitacao" asp-route-num="@Model.NumeroEdital.Replace("/", "-")">
        <div class="blog_details-widget mb-0">

            <div class="box-titulo-blue">
                <h4>Licitação Nº @Model.NumeroEdital</h4>
            </div>

            <div class="box-conteudo-ps">

                <h6>@Model.Objeto</h6>
                <p class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="18" fill="currentColor" class="bi bi-calendar-week" viewBox="0 0 16 16">
                        <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm-3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm-5 3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z"/>
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                    </svg>
                    Data da reunião: @Model.DataReuniao.ToShortDateString()
                </p>

                <p class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-square" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                        <path d="M10.97 4.97a.75.75 0 0 1 1.071 1.05l-3.992 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/>
                    </svg>
                    Situação:     <b class="@(Model.lct_statusLicitacao.Descricao == "Aguardando Abertura" ? "status-aaberto" : Model.lct_statusLicitacao.Descricao == "Aguardando Abertura" ? "status-aberto" :
Model.lct_statusLicitacao.Descricao == "Em Andamento" ? "status-andamento" :
"status-finalizado")">
                        @Model.lct_statusLicitacao.Descricao
                    </b>
                </p>

            </div>
        </div>

    </a>
</div>